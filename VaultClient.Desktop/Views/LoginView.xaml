<UserControl x:Class="VaultClient.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="400">

    <Border Background="#181825" CornerRadius="12" Padding="44,40"
            BorderBrush="#313244" BorderThickness="1">
        <StackPanel>

            <!-- Logo / Title -->
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="#252537" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="&#x1F512;" FontSize="24"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Vault Client"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Acesso seguro ao cofre corporativo"
                       FontSize="12" Foreground="#6C7086"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <!-- Toggle AD / Local -->
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E1E2E" CornerRadius="6,0,0,6" Padding="0,8">
                    <RadioButton x:Name="LocalRadio"
                                 Content=" Login Local"
                                 IsChecked="{Binding IsLocalLogin, Mode=OneWay}"
                                 GroupName="AuthMode"
                                 Foreground="#CDD6F4" FontSize="12"
                                 HorizontalAlignment="Center"
                                 Checked="LocalRadio_Checked"/>
                </Border>
                <Border Grid.Column="1" Background="#1E1E2E" CornerRadius="0,6,6,0" Padding="0,8">
                    <RadioButton x:Name="AdRadio"
                                 Content=" Active Directory"
                                 IsChecked="{Binding IsAdLogin, Mode=TwoWay}"
                                 GroupName="AuthMode"
                                 Foreground="#CDD6F4" FontSize="12"
                                 HorizontalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Username -->
            <TextBlock Text="Usuario" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="UsernameBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" Padding="12,10"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,16">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <!-- Password -->
            <TextBlock Text="Senha" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         FontSize="14" Padding="12,10"
                         Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" BorderThickness="1"
                         Margin="0,0,0,8">
                <PasswordBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </PasswordBox.Resources>
            </PasswordBox>

            <!-- Error message -->
            <Border Background="#2B0D0D" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NotEmptyToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#F38BA8" FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Login button -->
            <Button x:Name="LoginButton"
                    Content="Entrar"
                    FontSize="14" FontWeight="SemiBold"
                    Padding="0,12" Margin="0,8,0,0"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#89B4FA"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4D0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,12,0,0"
                         Foreground="#89B4FA" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Settings link -->
            <Button x:Name="SettingsButton"
                    Content="Configuracoes"
                    FontSize="12"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Background="Transparent" Foreground="#6C7086"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding GoToSettingsCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</UserControl>
