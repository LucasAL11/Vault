<UserControl x:Class="VaultClient.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="860" Height="540">

    <Border Background="{StaticResource Brush.AppBg}">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left: terminal/brand panel -->
                <ColumnDefinition Width="1.1*"/>
                <!-- Right: login form -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════
                 LEFT PANEL — Brand + terminal log
            ═══════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="#0C1610"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top: Sentil mark + node status -->
                    <Grid Grid.Row="0" Margin="28,22,28,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- S logo mark -->
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5 5 L19 5 L19 9 L9 9 L9 11 L19 11 L19 19 L5 19 L5 15 L15 15 L15 13 L5 13 Z"
                                          Fill="{StaticResource Brush.Accent}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="SENTINEL"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Fg}"
                                       VerticalAlignment="Center"
                                       Margin="9,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Brush.Accent}"
                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#7CE8A9" BlurRadius="6" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="NODE ACTIVE"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Accent}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Center: lock SVG -->
                    <Viewbox Grid.Row="1" Width="180" Height="180"
                             VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Canvas Width="220" Height="220">
                            <!-- outer ring -->
                            <Ellipse Canvas.Left="14" Canvas.Top="14" Width="192" Height="192"
                                     Fill="Transparent" Stroke="#7CE8A9" StrokeThickness="0.7" Opacity="0.20"/>
                            <!-- middle ring dashed -->
                            <Ellipse Canvas.Left="30" Canvas.Top="30" Width="160" Height="160"
                                     Fill="Transparent" Stroke="#7CE8A9" StrokeThickness="0.7" Opacity="0.32"
                                     StrokeDashArray="2 6"/>
                            <!-- inner ring -->
                            <Ellipse Canvas.Left="46" Canvas.Top="46" Width="128" Height="128"
                                     Fill="Transparent" Stroke="#7CE8A9" StrokeThickness="0.7" Opacity="0.44"
                                     StrokeDashArray="40 20"/>
                            <!-- cross hairs -->
                            <Line X1="10" Y1="110" X2="40" Y2="110" Stroke="#7CE8A9" StrokeThickness="0.6" Opacity="0.4"/>
                            <Line X1="180" Y1="110" X2="210" Y2="110" Stroke="#7CE8A9" StrokeThickness="0.6" Opacity="0.4"/>
                            <Line X1="110" Y1="10" X2="110" Y2="40" Stroke="#7CE8A9" StrokeThickness="0.6" Opacity="0.4"/>
                            <Line X1="110" Y1="180" X2="110" Y2="210" Stroke="#7CE8A9" StrokeThickness="0.6" Opacity="0.4"/>
                            <!-- lock body -->
                            <Rectangle Canvas.Left="92" Canvas.Top="100" Width="36" Height="28"
                                       Fill="Transparent" Stroke="#7CE8A9" StrokeThickness="1.4" RadiusX="2" RadiusY="2"/>
                            <!-- lock shackle -->
                            <Path Data="M98,100 v-8 a12,12 0 0 1 24,0 v8"
                                  Fill="Transparent" Stroke="#7CE8A9" StrokeThickness="1.4"/>
                            <!-- keyhole -->
                            <Ellipse Canvas.Left="108" Canvas.Top="112" Width="4" Height="4"
                                     Fill="{StaticResource Brush.Accent}"/>
                            <!-- hex label -->
                            <TextBlock Canvas.Left="74" Canvas.Top="150"
                                       Text="0x5ENT1L"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9" Foreground="#7CE8A9"
                                       Opacity="0.7"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Bottom: terminal log -->
                    <Border Grid.Row="2" Margin="20,0,20,24"
                            Background="#080F0A"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                <TextBlock Text="14:02:18" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#555C51" Width="58"/>
                                <TextBlock Text="SYS " FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#707A6A" FontWeight="SemiBold" Width="34"/>
                                <TextBlock Text="sentil.core booted · node plastcor-dc01" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#8A8F82"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                <TextBlock Text="14:02:19" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#555C51" Width="58"/>
                                <TextBlock Text="NET " FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#707A6A" FontWeight="SemiBold" Width="34"/>
                                <TextBlock Text="ldap://dc.plastcor.corp:636 ← tls handshake ok" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#8A8F82"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                <TextBlock Text="14:02:21" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#555C51" Width="58"/>
                                <TextBlock Text="VLT " FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#707A6A" FontWeight="SemiBold" Width="34"/>
                                <TextBlock Text="HSM online · vault sealed" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#8A8F82"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="14:02:24" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="#555C51" Width="58"/>
                                <TextBlock Text="AUTH" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Brush.Accent}" FontWeight="SemiBold" Width="34"/>
                                <TextBlock Text="awaiting subject credentials…" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Brush.Fg}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="▸" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Brush.Accent}" Margin="0,0,6,0"/>
                                <TextBlock Text="_" FontFamily="{StaticResource Font.Mono}" FontSize="10" Foreground="{StaticResource Brush.Accent}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════
                 RIGHT PANEL — Login form
            ═══════════════════════════════════════ -->
            <Border Grid.Column="1"
                    Background="{StaticResource Brush.SidebarBg}"
                    Padding="44,40,44,32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center">

                        <!-- Header label -->
                        <TextBlock Text="┌─ AUTH REQUIRED ─┐"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Accent}" Margin="0,0,0,18"/>

                        <!-- Title -->
                        <TextBlock Text="se.identifique"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="24" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Fg}"
                                   Margin="0,0,0,6"/>

                        <!-- Subtitle -->
                        <TextBlock FontFamily="{StaticResource Font.Mono}"
                                   FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                   Margin="0,0,0,28" LineHeight="18">
                            <Run Text="// Conecte-se com seu usuario."/>
                            <LineBreak/>
                            <Run Text="// todas as tentativas são registradas e assinadas."/>
                        </TextBlock>

                        <!-- Username -->
                        <TextBlock Text="// USUARIO"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                        <TextBox x:Name="UsernameBox"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SentilTextBox}"
                                 Margin="0,0,0,14"/>

                 

                        <!-- Password -->
                        <TextBlock Text="// SENHA"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource SentilPasswordBox}"
                                     Margin="0,0,0,10"/>

                        <!-- Error -->
                        <Border Background="#2A0A06"
                                BorderBrush="{StaticResource Brush.Danger}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="10,7" Margin="0,0,0,10"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NotEmptyToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕ " Foreground="{StaticResource Brush.Danger}" FontSize="11" FontFamily="{StaticResource Font.Mono}"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{StaticResource Brush.Danger}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Login button -->
                        <Button x:Name="LoginButton"
                                Content="&gt; auth.login()"
                                Style="{StaticResource SentilButtonAccent}"
                                IsDefault="True"
                                Margin="0,6,0,0"/>

                        <!-- Loading bar -->
                        <ProgressBar IsIndeterminate="True" Height="2" Margin="0,8,0,0"
                                     Foreground="{StaticResource Brush.Accent}"
                                     Background="Transparent" BorderThickness="0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <!-- Footer -->
                    <Grid Grid.Row="1">
                        <Button x:Name="SettingsButton"
                                Content="configuracoes"
                                FontFamily="{StaticResource Font.Mono}"
                                FontSize="10"
                                Background="Transparent"
                                Foreground="{StaticResource Brush.Muted}"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                Command="{Binding GoToSettingsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock HorizontalAlignment="Right"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                   Opacity="0.5">
                            <Run Text="v4.2.1"/>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>

