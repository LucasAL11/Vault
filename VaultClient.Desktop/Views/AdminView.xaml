<UserControl x:Class="VaultClient.Desktop.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VaultClient.Desktop.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource Brush.AppBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Body -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             HEADER
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource Brush.SidebarBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- S-mark -->
                    <Viewbox Width="13" Height="13" Margin="0,0,8,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M5 5 L19 5 L19 9 L9 9 L9 11 L19 11 L19 19 L5 19 L5 15 L15 15 L15 13 L5 13 Z"
                                  Fill="{StaticResource Brush.Accent}"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Admin"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Brush.Fg}"
                               VerticalAlignment="Center"/>

                    <!-- Role badge -->
                    <Border CornerRadius="2" Padding="7,2" Margin="12,0,0,0"
                            Background="{StaticResource Brush.ChipBg}"
                            VerticalAlignment="Center">
                        <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="9" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="ADMIN DE COFRE"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Muted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGlobalAdmin}" Value="True">
                                            <Setter Property="Text"       Value="ADMIN GERAL"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <Button Content="← voltar"
                        HorizontalAlignment="Right"
                        Command="{Binding BackToSecretsCommand}"
                        Style="{StaticResource SentilButtonGhost}"
                        FontFamily="{StaticResource Font.Mono}"
                        FontSize="11" Padding="14,6"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             BODY: SIDEBAR + CONTENT
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ───────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource Brush.SidebarBg}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar label -->
                    <Border Grid.Row="0" Padding="14,12,14,8"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="COFRES"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Muted}"/>
                    </Border>

                    <!-- Vault list -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Vaults}"
                             SelectedItem="{Binding SelectedVault, Mode=TwoWay}"
                             Style="{StaticResource SentilListBox}"
                             Padding="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:VaultItem}">
                                <Border Padding="14,10"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="28" Height="28"
                                                Background="{StaticResource Brush.ChipBg}"
                                                CornerRadius="2" Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Muted}"/>
                                                        <Setter Property="Text" Value="D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Environment}" Value="Production">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                                                <Setter Property="Text" Value="P"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Environment}" Value="Staging">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Warning}"/>
                                                                <Setter Property="Text" Value="S"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Fg}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Environment}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                                                <TextBlock Text=" · "
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10" Foreground="{StaticResource Brush.Border}"/>
                                                <TextBlock Text="{Binding Group}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty vault state -->
                    <TextBlock Grid.Row="1"
                               Text="// nenhum cofre"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="11" Foreground="{StaticResource Brush.Muted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Vaults.Count, Converter={StaticResource ZeroToVisibility}}"/>

                    <!-- New vault button (Global Admin only) -->
                    <Border Grid.Row="2" Padding="10,8,10,10"
                            Visibility="{Binding IsGlobalAdmin, Converter={StaticResource BoolToVisibility}}">
                        <Button Command="{Binding OpenCreateVaultFormCommand}"
                                Style="{StaticResource SentilButtonAccent}"
                                FontSize="12" Padding="0,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold" Margin="0,-1,6,0"/>
                                <TextBlock Text="novo cofre" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{StaticResource Brush.Border}"/>

            <!-- ── CONTENT ────────────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- STATE 1: No vault + no form => Welcome -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="{Binding HasSelectedVault, Converter={StaticResource InverseBoolToVisibility}}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCreateVaultForm}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="[ ]"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="36" Foreground="{StaticResource Brush.Border}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="selecione um cofre"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="13" Foreground="{StaticResource Brush.Muted}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="// escolha na barra lateral para gerenciar segredos, AD maps e autofill"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="10" Foreground="{StaticResource Brush.Border}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Button Content="criar primeiro cofre"
                            Margin="0,20,0,0"
                            Command="{Binding OpenCreateVaultFormCommand}"
                            Style="{StaticResource SentilButtonAccent}"
                            FontSize="12" Padding="24,10"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsGlobalAdmin, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- STATE 2: Create vault form -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ShowCreateVaultForm, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel MaxWidth="520" Margin="32,24" HorizontalAlignment="Left">

                        <TextBlock Text="// novo cofre"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Accent}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Criar Cofre"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Fg}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Organize segredos por equipe, projeto ou ambiente."
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                   Margin="0,0,0,24"/>

                        <!-- Nome -->
                        <TextBlock Text="// NOME *" FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewVaultName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SentilTextBox}" Margin="0,0,0,4"/>
                        <TextBlock Text="ex: TI Producao, Cofre Licitacoes"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Border}" Margin="0,0,0,16"/>

                        <!-- Slug -->
                        <TextBlock Text="// SLUG" FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewVaultSlug, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SentilTextBox}" Margin="0,0,0,4"/>
                        <TextBlock Text="gerado automaticamente — usado em URLs e automacoes"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Border}" Margin="0,0,0,16"/>

                        <!-- Tenant + Grupo AD -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="// TENANT ID *" FontFamily="{StaticResource Font.Mono}"
                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewVaultTenantId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SentilTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="// GRUPO AD *" FontFamily="{StaticResource Font.Mono}"
                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewVaultGroup, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SentilTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Ambiente -->
                        <TextBlock Text="// AMBIENTE" FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton Content="Production"  GroupName="VaultEnv" IsChecked="True"
                                         Foreground="{StaticResource Brush.Fg}" FontFamily="{StaticResource Font.Mono}"
                                         FontSize="11" Margin="0,0,20,0" Tag="Production" Checked="VaultEnv_Checked"/>
                            <RadioButton Content="Staging"     GroupName="VaultEnv"
                                         Foreground="{StaticResource Brush.Fg}" FontFamily="{StaticResource Font.Mono}"
                                         FontSize="11" Margin="0,0,20,0" Tag="Staging" Checked="VaultEnv_Checked"/>
                            <RadioButton Content="Development" GroupName="VaultEnv"
                                         Foreground="{StaticResource Brush.Fg}" FontFamily="{StaticResource Font.Mono}"
                                         FontSize="11" Tag="Development" Checked="VaultEnv_Checked"/>
                        </StackPanel>

                        <!-- Descrição -->
                        <TextBlock Text="// DESCRICAO" FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewVaultDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SentilTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="56" MaxHeight="90"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Command="{Binding CreateVaultCommand}"
                                    Style="{StaticResource SentilButtonAccent}"
                                    FontSize="12" Padding="24,10" Margin="0,0,10,0"
                                    Content="criar cofre"/>
                            <Button Command="{Binding CancelCreateVaultCommand}"
                                    Style="{StaticResource SentilButtonGhost}"
                                    FontSize="11" Padding="18,10" Content="cancelar"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- STATE 3: Vault selected -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility"
                                    Value="{Binding SelectedVault, Converter={StaticResource NullToVisibility}}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCreateVaultForm}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Vault banner -->
                        <RowDefinition Height="Auto"/>   <!-- Edit form -->
                        <RowDefinition Height="*"/>      <!-- Tabs -->
                    </Grid.RowDefinitions>

                    <!-- Vault banner -->
                    <Border Grid.Row="0"
                            Background="{StaticResource Brush.SidebarBg}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="24,14">
                        <Grid>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding SelectedVault.Name}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource Brush.Fg}"/>
                                    <Border CornerRadius="2" Padding="7,2" Margin="10,0,0,0"
                                            Background="{StaticResource Brush.ChipBg}"
                                            VerticalAlignment="Center">
                                        <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="9" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Muted}"/>
                                                    <Setter Property="Text" Value="{Binding SelectedVault.Environment}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedVault.Environment}" Value="Production">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedVault.Environment}" Value="Staging">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Warning}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <TextBlock FontFamily="{StaticResource Font.Mono}"
                                           FontSize="10" Foreground="{StaticResource Brush.Muted}">
                                    <Run Text="{Binding SelectedVault.Group}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding SelectedVault.Slug}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Command="{Binding OpenEditVaultFormCommand}"
                                        Content="editar"
                                        Style="{StaticResource SentilButtonGhost}"
                                        FontFamily="{StaticResource Font.Mono}"
                                        FontSize="11" Padding="12,5" Margin="0,0,6,0"/>
                                <Button Command="{Binding DeleteVaultCommand}"
                                        Content="excluir"
                                        Style="{StaticResource SentilButtonGhost}"
                                        FontFamily="{StaticResource Font.Mono}"
                                        FontSize="11" Padding="12,5"
                                        Foreground="{StaticResource Brush.Danger}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Edit vault inline form -->
                    <Border Grid.Row="1"
                            Background="{StaticResource Brush.ListBg}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="24,14"
                            Visibility="{Binding ShowEditVaultForm, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="// editar cofre"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding EditVaultName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SentilTextBox}"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding EditVaultDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SentilTextBox}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Command="{Binding SaveVaultCommand}"
                                        Content="salvar"
                                        Style="{StaticResource SentilButtonAccent}"
                                        FontSize="11" Padding="18,7" Margin="0,0,8,0"/>
                                <Button Command="{Binding CancelEditVaultCommand}"
                                        Content="cancelar"
                                        Style="{StaticResource SentilButtonGhost}"
                                        FontSize="11" Padding="18,7"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Tabs -->
                    <TabControl Grid.Row="2"
                                SelectedIndex="{Binding SelectedTab}"
                                Background="{StaticResource Brush.AppBg}"
                                BorderThickness="0" Padding="0" Margin="20,8,20,0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background"    Value="Transparent"/>
                                <Setter Property="Foreground"    Value="{StaticResource Brush.Muted}"/>
                                <Setter Property="Padding"       Value="14,7"/>
                                <Setter Property="FontSize"      Value="11"/>
                                <Setter Property="FontFamily"    Value="{StaticResource Font.Mono}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0,0,0,2">
                                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush"
                                                            Value="{StaticResource Brush.Accent}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Fg}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Fg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- ── Tab: Segredos ── -->
                        <TabItem Header="segredos">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Form -->
                                <Border Grid.Row="0" CornerRadius="2" Padding="18,14" Margin="0,0,0,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Brush.SidebarBg}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingSecret}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Brush.ListBg}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Fg}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="// adicionar segredo"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingSecret}" Value="True">
                                                                <Setter Property="Text" Value="// editar segredo"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button HorizontalAlignment="Right"
                                                    Content="cancelar edicao"
                                                    Command="{Binding CancelEditSecretCommand}"
                                                    Style="{StaticResource SentilButtonGhost}"
                                                    FontFamily="{StaticResource Font.Mono}"
                                                    FontSize="10" Padding="10,4"
                                                    Visibility="{Binding IsEditingSecret, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="// NOME" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewSecretName, UpdateSourceTrigger=PropertyChanged}"
                                                         IsReadOnly="{Binding IsEditingSecret}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="// TIPO" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewSecretContentType, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="// VALOR"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditingSecret}" Value="True">
                                                                    <Setter Property="Text" Value="// NOVO VALOR"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Text="{Binding NewSecretValue, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>

                                            <Button Grid.Column="6"
                                                    Command="{Binding CreateSecretCommand}"
                                                    Style="{StaticResource SentilButtonAccent}"
                                                    FontSize="11" Padding="18,0"
                                                    VerticalAlignment="Bottom" Height="36">
                                                <Button.Content>
                                                    <TextBlock FontFamily="{StaticResource Font.Mono}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="salvar"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditingSecret}" Value="True">
                                                                        <Setter Property="Text" Value="atualizar"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button.Content>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Secrets list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding Secrets}"
                                             Style="{StaticResource SentilListBox}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:SecretItem}">
                                                <Border Padding="14,11"
                                                        BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brush.Fg}"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <Border Background="{StaticResource Brush.ChipBg}"
                                                                        CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                                               FontFamily="{StaticResource Font.Mono}"
                                                                               FontSize="9" Foreground="{StaticResource Brush.Muted}"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding ContentType}"
                                                                           FontFamily="{StaticResource Font.Mono}"
                                                                           FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="editar"
                                                                Command="{Binding DataContext.EditSecretCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SentilButtonGhost}"
                                                                FontFamily="{StaticResource Font.Mono}"
                                                                FontSize="10" Padding="10,4" Margin="0,0,6,0"/>
                                                        <Button Grid.Column="2" Content="desativar"
                                                                Command="{Binding DataContext.DeleteSecretCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SentilButtonGhost}"
                                                                FontFamily="{StaticResource Font.Mono}"
                                                                FontSize="10" Padding="10,4"
                                                                Foreground="{StaticResource Brush.Danger}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding Secrets.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="[ ]" FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="24" Foreground="{StaticResource Brush.Border}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="nenhum segredo neste cofre"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ── Tab: AD Maps ── -->
                        <TabItem Header="permissoes AD">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Form -->
                                <Border Grid.Row="0"
                                        Background="{StaticResource Brush.SidebarBg}"
                                        CornerRadius="2" Padding="18,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="// vincular grupo AD"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Fg}" Margin="0,0,0,4"/>
                                        <TextBlock Text="membros do grupo terao acesso aos segredos conforme a permissao"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="// GRUPO" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewAdMapGroupId, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="// PERMISSAO" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedItem="{Binding NewAdMapPermission}"
                                                          Background="{StaticResource Brush.FieldBg}"
                                                          Foreground="{StaticResource Brush.Fg}"
                                                          BorderBrush="{StaticResource Brush.Border}"
                                                          FontFamily="{StaticResource Font.Mono}"
                                                          FontSize="12" Padding="8,6">
                                                    <sys:String>Read</sys:String>
                                                    <sys:String>Write</sys:String>
                                                    <sys:String>Admin</sys:String>
                                                </ComboBox>
                                            </StackPanel>

                                            <Button Grid.Column="4" Content="vincular"
                                                    Command="{Binding CreateAdMapCommand}"
                                                    Style="{StaticResource SentilButtonAccent}"
                                                    FontFamily="{StaticResource Font.Mono}"
                                                    FontSize="11" Padding="18,0"
                                                    VerticalAlignment="Bottom" Height="36"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- AD Maps list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding AdMaps}"
                                             Style="{StaticResource SentilListBox}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:AdMapItem}">
                                                <Border Padding="14,11"
                                                        BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding GroupId}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Brush.Fg}"
                                                                   VerticalAlignment="Center"/>

                                                        <Border Grid.Column="1" CornerRadius="2" Padding="7,2"
                                                                Margin="8,0" Background="{StaticResource Brush.ChipBg}"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Permission}"
                                                                       FontFamily="{StaticResource Font.Mono}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brush.Accent}"/>
                                                        </Border>

                                                        <Border Grid.Column="2" CornerRadius="2" Padding="7,2"
                                                                Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#162218"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Background" Value="#2A1410"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                                       FontSize="9" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="ATIVO"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                <Setter Property="Text" Value="INATIVO"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <Button Grid.Column="3" Content="remover"
                                                                Command="{Binding DataContext.DeleteAdMapCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SentilButtonGhost}"
                                                                FontFamily="{StaticResource Font.Mono}"
                                                                FontSize="10" Padding="10,4"
                                                                Foreground="{StaticResource Brush.Danger}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding AdMaps.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="[ ]" FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="24" Foreground="{StaticResource Brush.Border}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="nenhum grupo vinculado"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ── Tab: Usuarios Locais (Global Admin only) ── -->
                        <TabItem Header="usuarios"
                                 Visibility="{Binding IsGlobalAdmin, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Form -->
                                <Border Grid.Row="0"
                                        Background="{StaticResource Brush.SidebarBg}"
                                        CornerRadius="2" Padding="18,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="// registrar usuario local"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Fg}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1 -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="// USUARIO" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewUserUsername, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="// SENHA" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <PasswordBox x:Name="NewUserPasswordBox"
                                                             Style="{StaticResource SentilPasswordBox}"/>
                                            </StackPanel>

                                            <!-- Row 2 -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                                <TextBlock Text="// NOME" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewUserFirstName, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>
                                            <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="// SOBRENOME" FontFamily="{StaticResource Font.Mono}"
                                                               FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                    <TextBox Text="{Binding NewUserLastName, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource SentilTextBox}"/>
                                                </StackPanel>
                                                <Button x:Name="CreateUserButton" Grid.Column="2"
                                                        Content="criar"
                                                        Style="{StaticResource SentilButtonAccent}"
                                                        FontFamily="{StaticResource Font.Mono}"
                                                        FontSize="11" Padding="18,0"
                                                        VerticalAlignment="Bottom" Height="36"/>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Users list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding Users}"
                                             Style="{StaticResource SentilListBox}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:UserItem}">
                                                <Border Padding="14,10"
                                                        BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="32" Height="32"
                                                                Background="{StaticResource Brush.Accent}"
                                                                CornerRadius="16" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding Initials}"
                                                                       FontFamily="{StaticResource Font.Mono}"
                                                                       FontSize="12" FontWeight="Bold"
                                                                       Foreground="#181e1c"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Username}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brush.Fg}"/>
                                                            <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                                       FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                                                       Margin="0,2,0,0">
                                                                <Run Text="{Binding FirstName}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding LastName}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding Users.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="[ ]" FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="24" Foreground="{StaticResource Brush.Border}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="nenhum usuario local"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ── Tab: Autofill ── -->
                        <TabItem Header="autofill">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Form -->
                                <Border Grid.Row="0" CornerRadius="2" Padding="18,14" Margin="0,0,0,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Brush.SidebarBg}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingRule}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Brush.ListBg}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Fg}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="// nova regra de autofill"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingRule}" Value="True">
                                                                <Setter Property="Text" Value="// editar regra de autofill"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button HorizontalAlignment="Right"
                                                    Content="cancelar edicao"
                                                    Command="{Binding CancelEditRuleCommand}"
                                                    Style="{StaticResource SentilButtonGhost}"
                                                    FontFamily="{StaticResource Font.Mono}"
                                                    FontSize="10" Padding="10,4"
                                                    Visibility="{Binding IsEditingRule, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                        <TextBlock Text="define login e segredo para preencher automaticamente para um host ou app"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="// HOST / URL" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewRuleUrlPattern, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="// LOGIN" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewRuleLogin, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="// SEGREDO" FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewRuleSecretName, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentilTextBox}"/>
                                            </StackPanel>

                                            <Button Grid.Column="6"
                                                    Command="{Binding CreateAutofillRuleCommand}"
                                                    Style="{StaticResource SentilButtonAccent}"
                                                    FontFamily="{StaticResource Font.Mono}"
                                                    FontSize="11" Padding="18,0"
                                                    VerticalAlignment="Bottom" Height="36">
                                                <Button.Content>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="adicionar"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditingRule}" Value="True">
                                                                        <Setter Property="Text" Value="atualizar"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button.Content>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Rules list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding AutofillRules}"
                                             Style="{StaticResource SentilListBox}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:AutofillRuleItem}">
                                                <Border Padding="14,11"
                                                        BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding UrlPattern}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brush.Fg}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Text="{Binding Login}"
                                                                           FontFamily="{StaticResource Font.Mono}"
                                                                           FontSize="10" Foreground="{StaticResource Brush.Accent}"/>
                                                                <TextBlock Text=" → "
                                                                           FontFamily="{StaticResource Font.Mono}"
                                                                           FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                                                                <TextBlock Text="{Binding SecretName}"
                                                                           FontFamily="{StaticResource Font.Mono}"
                                                                           FontSize="10" Foreground="{StaticResource Brush.Success}"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Border Grid.Column="1" CornerRadius="2" Padding="7,2"
                                                                Margin="8,0,10,0" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#162218"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Background" Value="#2A1410"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontFamily="{StaticResource Font.Mono}"
                                                                       FontSize="9" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="ATIVO"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                <Setter Property="Text" Value="INATIVO"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <Button Grid.Column="2" Content="editar"
                                                                Command="{Binding DataContext.EditAutofillRuleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SentilButtonGhost}"
                                                                FontFamily="{StaticResource Font.Mono}"
                                                                FontSize="10" Padding="10,4" Margin="0,0,6,0"/>
                                                        <Button Grid.Column="3" Content="remover"
                                                                Command="{Binding DataContext.DeleteAutofillRuleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SentilButtonGhost}"
                                                                FontFamily="{StaticResource Font.Mono}"
                                                                FontSize="10" Padding="10,4"
                                                                Foreground="{StaticResource Brush.Danger}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding AutofillRules.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="[ ]" FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="24" Foreground="{StaticResource Brush.Border}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="nenhuma regra de autofill"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             STATUS BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="16,8"
                Background="{Binding StatusType, Converter={StaticResource StatusTypeToBgBrush}}">
            <Grid>
                <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top"
                             Foreground="{StaticResource Brush.Accent}"
                             Background="Transparent" BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontFamily="{StaticResource Font.Mono}" FontSize="10"
                           Foreground="{Binding StatusType, Converter={StaticResource StatusTypeToBrush}}"
                           VerticalAlignment="Center"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NotEmptyToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
