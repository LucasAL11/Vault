<UserControl x:Class="VaultClient.Desktop.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VaultClient.Desktop.Models"
             Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Body: Sidebar + Content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                             -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#181825" Padding="20,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Painel Administrativo" FontSize="16" FontWeight="Bold"
                               Foreground="#CDD6F4"/>
                    <Border Background="#302040" CornerRadius="4" Padding="8,3" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="ADMIN" FontSize="10" FontWeight="Bold" Foreground="#CBA6F7"/>
                    </Border>
                </StackPanel>

                <Button Content="Voltar" HorizontalAlignment="Right"
                        Command="{Binding BackToSecretsCommand}"
                        FontSize="12" Padding="16,7"
                        Background="Transparent" Foreground="#6C7086"
                        BorderBrush="#45475A" BorderThickness="1" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderBrush" Value="#CDD6F4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- BODY: SIDEBAR + CONTENT                                            -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>   <!-- Sidebar -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="*"/>     <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR: Vault List ═══ -->
            <Grid Grid.Column="0" Background="#181825">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Sidebar header -->
                    <RowDefinition Height="*"/>     <!-- Vault list -->
                    <RowDefinition Height="Auto"/>  <!-- New vault button -->
                </Grid.RowDefinitions>

                <!-- Sidebar header -->
                <Border Grid.Row="0" Padding="16,14,16,10">
                    <TextBlock Text="COFRES" FontSize="11" FontWeight="Bold"
                               Foreground="#6C7086"/>
                </Border>

                <!-- Vault list -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Vaults}"
                         SelectedItem="{Binding SelectedVault, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="4,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="4,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="12,10">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#252537"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:VaultItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Vault icon -->
                                <Border Grid.Column="0" Width="32" Height="32"
                                        CornerRadius="6" Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E3A5F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Environment}" Value="Production">
                                                    <Setter Property="Background" Value="#1A3A1A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Environment}" Value="Staging">
                                                    <Setter Property="Background" Value="#3A3A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="D"/>
                                                <Setter Property="Foreground" Value="#89B4FA"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Environment}" Value="Production">
                                                        <Setter Property="Text" Value="P"/>
                                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Environment}" Value="Staging">
                                                        <Setter Property="Text" Value="S"/>
                                                        <Setter Property="Foreground" Value="#F9E2AF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Vault info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                               Foreground="#CDD6F4" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Environment}" FontSize="10"
                                                   Foreground="#6C7086"/>
                                        <TextBlock Text=" · " FontSize="10" Foreground="#45475A"/>
                                        <TextBlock Text="{Binding Group}" FontSize="10"
                                                   Foreground="#6C7086" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty vault state -->
                <TextBlock Grid.Row="1" Text="Nenhum cofre criado"
                           FontSize="12" Foreground="#45475A"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Vaults.Count, Converter={StaticResource ZeroToVisibility}}"/>

                <!-- New vault button -->
                <Border Grid.Row="2" Padding="12,8,12,12">
                    <Button Command="{Binding OpenCreateVaultFormCommand}"
                            FontSize="12" Padding="0,10"
                            Background="#CBA6F7" Foreground="#1E1E2E"
                            BorderThickness="0" Cursor="Hand"
                            FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </Button.Resources>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,-2,6,0"/>
                                <TextBlock Text="Novo Cofre" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D4B8FC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>
            </Grid>

            <!-- Divider -->
            <Border Grid.Column="1" Background="#313244"/>

            <!-- ═══ CONTENT AREA ═══ -->
            <Grid Grid.Column="2">

                <!-- STATE 1: No vault selected + no create form => Welcome -->
                <Border Visibility="{Binding HasSelectedVault, Converter={StaticResource InverseBoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCreateVaultForm}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <Border Width="64" Height="64" CornerRadius="32"
                                Background="#252537" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F512;" FontSize="28"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Selecione um cofre" FontSize="18" FontWeight="SemiBold"
                                   Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Escolha um cofre na barra lateral para gerenciar&#x0a;seus segredos, permissoes e mapeamentos AD."
                                   FontSize="13" Foreground="#6C7086" TextAlignment="Center"
                                   LineHeight="20"/>
                        <Button Content="Criar primeiro cofre" Margin="0,20,0,0"
                                Command="{Binding OpenCreateVaultFormCommand}"
                                FontSize="13" Padding="20,10"
                                Background="#CBA6F7" Foreground="#1E1E2E"
                                BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Visibility="{Binding Vaults.Count, Converter={StaticResource ZeroToVisibility}}">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- STATE 2: Create vault form -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ShowCreateVaultForm, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel MaxWidth="520" Margin="32,24,32,24" HorizontalAlignment="Left">

                        <!-- Form header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <TextBlock Text="Novo Cofre" FontSize="20" FontWeight="Bold"
                                       Foreground="#CDD6F4" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Crie um cofre para organizar segredos por equipe, projeto ou ambiente."
                                   FontSize="13" Foreground="#6C7086" Margin="0,0,0,24" LineHeight="20"/>

                        <!-- Nome do Cofre -->
                        <TextBlock Text="Nome do Cofre *" Foreground="#BAC2DE" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NewVaultName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="12,10"
                                 Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" BorderThickness="1"
                                 CaretBrush="#CDD6F4" Margin="0,0,0,4">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="Ex: TI Producao, Cofre Licitacoes, DevOps Staging"
                                   FontSize="11" Foreground="#585B70" Margin="0,0,0,16"/>

                        <!-- Slug -->
                        <TextBlock Text="Slug (identificador unico)" Foreground="#BAC2DE" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NewVaultSlug, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="12,10"
                                 Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" BorderThickness="1"
                                 CaretBrush="#CDD6F4" Margin="0,0,0,4">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="Gerado automaticamente a partir do nome. Usado em URLs e automacoes."
                                   FontSize="11" Foreground="#585B70" Margin="0,0,0,16"/>

                        <!-- Row: Tenant ID + Grupo AD -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tenant ID *" Foreground="#BAC2DE" FontSize="12"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding NewVaultTenantId, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="12,10"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="Identificador da organizacao" FontSize="11"
                                           Foreground="#585B70" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Grupo AD *" Foreground="#BAC2DE" FontSize="12"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding NewVaultGroup, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="12,10"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="Grupo proprietario do cofre" FontSize="11"
                                           Foreground="#585B70" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row: Ambiente + Descricao -->
                        <TextBlock Text="Ambiente" Foreground="#BAC2DE" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton Content="  Production" GroupName="VaultEnv"
                                         IsChecked="True"
                                         Foreground="#CDD6F4" FontSize="12" Margin="0,0,20,0"
                                         Tag="Production" Checked="VaultEnv_Checked"/>
                            <RadioButton Content="  Staging" GroupName="VaultEnv"
                                         Foreground="#CDD6F4" FontSize="12" Margin="0,0,20,0"
                                         Tag="Staging" Checked="VaultEnv_Checked"/>
                            <RadioButton Content="  Development" GroupName="VaultEnv"
                                         Foreground="#CDD6F4" FontSize="12"
                                         Tag="Development" Checked="VaultEnv_Checked"/>
                        </StackPanel>

                        <!-- Descricao -->
                        <TextBlock Text="Descricao (opcional)" Foreground="#BAC2DE" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NewVaultDescription, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="12,10"
                                 Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" BorderThickness="1"
                                 CaretBrush="#CDD6F4" Margin="0,0,0,24"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="60" MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding CreateVaultCommand}"
                                    FontSize="13" Padding="24,10"
                                    Background="#CBA6F7" Foreground="#1E1E2E"
                                    BorderThickness="0" Cursor="Hand"
                                    FontWeight="SemiBold" Margin="0,0,10,0">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                </Button.Resources>
                                <Button.Content>
                                    <TextBlock Text="Criar Cofre"/>
                                </Button.Content>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#D4B8FC"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#45475A"/>
                                                <Setter Property="Foreground" Value="#6C7086"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Cancelar"
                                    Command="{Binding CancelCreateVaultCommand}"
                                    FontSize="13" Padding="24,10"
                                    Background="Transparent" Foreground="#6C7086"
                                    BorderBrush="#45475A" BorderThickness="1" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#CDD6F4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- STATE 3: Vault selected => Tabs content -->
                <Grid Visibility="{Binding SelectedVault, Converter={StaticResource NullToVisibility}}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCreateVaultForm}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Vault context banner -->
                        <RowDefinition Height="*"/>     <!-- Tab content -->
                    </Grid.RowDefinitions>

                    <!-- Vault context banner -->
                    <Border Grid.Row="0" Background="#1E1E2E" Padding="24,16,24,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding SelectedVault.Name}" FontSize="18" FontWeight="Bold"
                                           Foreground="#CDD6F4"/>
                                <Border CornerRadius="4" Padding="8,3" Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E3A5F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedVault.Environment}" Value="Production">
                                                    <Setter Property="Background" Value="#1A3A1A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedVault.Environment}" Value="Staging">
                                                    <Setter Property="Background" Value="#3A3A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#89B4FA"/>
                                                <Setter Property="Text" Value="{Binding SelectedVault.Environment}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedVault.Environment}" Value="Production">
                                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedVault.Environment}" Value="Staging">
                                                        <Setter Property="Foreground" Value="#F9E2AF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="12" Foreground="#6C7086">
                                <Run Text="{Binding SelectedVault.Group}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding SelectedVault.Slug}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding SelectedVault.Id, StringFormat='{}{0:N}'}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Tabs -->
                    <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}"
                                Background="#1E1E2E" BorderThickness="0" Padding="0" Margin="20,4,20,0">

                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                                <Setter Property="Padding" Value="16,8"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                                <ContentPresenter ContentSource="Header"
                                                                  HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#CBA6F7"/>
                                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- ═══ Tab: Segredos ═══ -->
                        <TabItem Header="Segredos">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Create secret form -->
                                <Border Grid.Row="0" Background="#181825" CornerRadius="8"
                                        Padding="20,16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Adicionar Segredo" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#CDD6F4" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 1: Name + ContentType -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="Nome" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewSecretName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" Padding="10,8"
                                                         Background="#313244" Foreground="#CDD6F4"
                                                         BorderBrush="#45475A" BorderThickness="1"
                                                         CaretBrush="#CDD6F4">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="Tipo" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewSecretContentType, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" Padding="10,8"
                                                         Background="#313244" Foreground="#CDD6F4"
                                                         BorderBrush="#45475A" BorderThickness="1"
                                                         CaretBrush="#CDD6F4">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>

                                            <!-- Row 2: Value + Button -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0">
                                                <TextBlock Text="Valor" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding NewSecretValue, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="12" Padding="10,8"
                                                             Background="#313244" Foreground="#CDD6F4"
                                                             BorderBrush="#45475A" BorderThickness="1"
                                                             CaretBrush="#CDD6F4" Margin="0,0,10,0">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                    <Button Grid.Column="1" Content="Salvar"
                                                            Command="{Binding CreateSecretCommand}"
                                                            FontSize="12" Padding="20,8"
                                                            Background="#89B4FA" Foreground="#1E1E2E"
                                                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                        </Button.Resources>
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Background" Value="#45475A"/>
                                                                        <Setter Property="Foreground" Value="#6C7086"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Secrets list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding Secrets}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252537"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:SecretItem}">
                                                <Border Padding="14,12" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                                       Foreground="#CDD6F4"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <Border Background="#252537" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                                               FontSize="10" Foreground="#6C7086"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding ContentType}"
                                                                           FontSize="11" Foreground="#585B70"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="Desativar"
                                                                Command="{Binding DataContext.DeleteSecretCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                FontSize="11" Padding="12,6"
                                                                Background="Transparent" Foreground="#F38BA8"
                                                                BorderBrush="#45475A" BorderThickness="1"
                                                                Cursor="Hand">
                                                            <Button.Resources>
                                                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                            </Button.Resources>
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#F38BA8"/>
                                                                            <Setter Property="Background" Value="#2B0D0D"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Empty state -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding Secrets.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="Nenhum segredo neste cofre"
                                                   FontSize="14" Foreground="#585B70"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Use o formulario acima para adicionar o primeiro segredo."
                                                   FontSize="12" Foreground="#45475A"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ═══ Tab: AD Maps ═══ -->
                        <TabItem Header="Permissoes AD">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Info banner -->
                                <Border Grid.Row="0" Background="#181825" CornerRadius="8"
                                        Padding="20,16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Vincular Grupo AD" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#CDD6F4" Margin="0,0,0,4"/>
                                        <TextBlock Text="Membros do grupo terao acesso aos segredos deste cofre conforme a permissao."
                                                   FontSize="11" Foreground="#585B70" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Grupo AD" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewAdMapGroupId, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" Padding="10,8"
                                                         Background="#313244" Foreground="#CDD6F4"
                                                         BorderBrush="#45475A" BorderThickness="1"
                                                         CaretBrush="#CDD6F4">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Permissao" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <ComboBox SelectedItem="{Binding NewAdMapPermission}"
                                                          FontSize="12" Padding="10,6"
                                                          Background="#313244" Foreground="#CDD6F4"
                                                          BorderBrush="#45475A" BorderThickness="1">
                                                    <ComboBoxItem Content="Read"/>
                                                    <ComboBoxItem Content="Write"/>
                                                    <ComboBoxItem Content="Admin"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <Button Grid.Column="4" Content="Vincular"
                                                    Command="{Binding CreateAdMapCommand}"
                                                    FontSize="12" Padding="20,8"
                                                    Background="#89B4FA" Foreground="#1E1E2E"
                                                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                                                    VerticalAlignment="Bottom">
                                                <Button.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                </Button.Resources>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#45475A"/>
                                                                <Setter Property="Foreground" Value="#6C7086"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- AD Maps list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding AdMaps}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252537"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:AdMapItem}">
                                                <Border Padding="14,12" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding GroupId}"
                                                                   FontSize="13" Foreground="#CDD6F4"
                                                                   FontWeight="Medium" VerticalAlignment="Center"/>

                                                        <!-- Permission badge -->
                                                        <Border Grid.Column="1" CornerRadius="4" Padding="8,3" Margin="8,0"
                                                                VerticalAlignment="Center" Background="#1E3A5F">
                                                            <TextBlock Text="{Binding Permission}" FontSize="11"
                                                                       Foreground="#89B4FA" FontWeight="SemiBold"/>
                                                        </Border>

                                                        <!-- Status badge -->
                                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,3" Margin="0,0,10,0"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1A3A1A"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Background" Value="#2B0D0D"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="Ativo"/>
                                                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                <Setter Property="Text" Value="Inativo"/>
                                                                                <Setter Property="Foreground" Value="#F38BA8"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <Button Grid.Column="3" Content="Remover"
                                                                Command="{Binding DataContext.DeleteAdMapCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                FontSize="11" Padding="12,6"
                                                                Background="Transparent" Foreground="#F38BA8"
                                                                BorderBrush="#45475A" BorderThickness="1"
                                                                Cursor="Hand">
                                                            <Button.Resources>
                                                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                            </Button.Resources>
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#F38BA8"/>
                                                                            <Setter Property="Background" Value="#2B0D0D"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Empty state -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding AdMaps.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="Nenhum grupo vinculado"
                                                   FontSize="14" Foreground="#585B70"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Vincule um grupo AD para controlar quem acessa os segredos deste cofre."
                                                   FontSize="12" Foreground="#45475A"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ═══ Tab: Usuarios Locais ═══ -->
                        <TabItem Header="Usuarios">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Create user form -->
                                <Border Grid.Row="0" Background="#181825" CornerRadius="8"
                                        Padding="20,16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Registrar Usuario Local" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#CDD6F4" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1: Username + Password -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="Usuario" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewUserUsername, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" Padding="10,8"
                                                         Background="#313244" Foreground="#CDD6F4"
                                                         BorderBrush="#45475A" BorderThickness="1"
                                                         CaretBrush="#CDD6F4">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="Senha" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <PasswordBox x:Name="NewUserPasswordBox"
                                                             FontSize="12" Padding="10,8"
                                                             Background="#313244" Foreground="#CDD6F4"
                                                             BorderBrush="#45475A" BorderThickness="1">
                                                    <PasswordBox.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </PasswordBox.Resources>
                                                </PasswordBox>
                                            </StackPanel>

                                            <!-- Row 2: FirstName + LastName + Button -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                                <TextBlock Text="Nome" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding NewUserFirstName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" Padding="10,8"
                                                         Background="#313244" Foreground="#CDD6F4"
                                                         BorderBrush="#45475A" BorderThickness="1"
                                                         CaretBrush="#CDD6F4">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                            <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                    <TextBlock Text="Sobrenome" Foreground="#585B70" FontSize="11" Margin="0,0,0,4"/>
                                                    <TextBox Text="{Binding NewUserLastName, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="12" Padding="10,8"
                                                             Background="#313244" Foreground="#CDD6F4"
                                                             BorderBrush="#45475A" BorderThickness="1"
                                                             CaretBrush="#CDD6F4">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </StackPanel>
                                                <Button x:Name="CreateUserButton" Grid.Column="1"
                                                        Content="Criar" VerticalAlignment="Bottom"
                                                        FontSize="12" Padding="20,8"
                                                        Background="#89B4FA" Foreground="#1E1E2E"
                                                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </Button.Resources>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Background" Value="#45475A"/>
                                                                    <Setter Property="Foreground" Value="#6C7086"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Users list -->
                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding Users}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252537"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:UserItem}">
                                                <Border Padding="14,10" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="#302040" CornerRadius="16"
                                                                Width="36" Height="36" Margin="0,0,12,0">
                                                            <TextBlock Text="U" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="#CBA6F7"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Username}" FontSize="13"
                                                                       FontWeight="Medium" Foreground="#CDD6F4"/>
                                                            <TextBlock FontSize="11" Foreground="#6C7086" Margin="0,2,0,0">
                                                                <Run Text="{Binding FirstName}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding LastName}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Empty state -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding Users.Count, Converter={StaticResource ZeroToVisibility}}">
                                        <TextBlock Text="Nenhum usuario local"
                                                   FontSize="14" Foreground="#585B70"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Registre usuarios locais para acesso sem Active Directory."
                                                   FontSize="12" Foreground="#45475A"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                         -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="16,10"
                Background="{Binding StatusType, Converter={StaticResource StatusTypeToBgBrush}}">
            <Grid>
                <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top"
                             Foreground="#CBA6F7" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{Binding StatusType, Converter={StaticResource StatusTypeToBrush}}"
                           VerticalAlignment="Center"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NotEmptyToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
