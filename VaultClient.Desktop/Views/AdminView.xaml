<UserControl x:Class="VaultClient.Desktop.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VaultClient.Desktop.Models"
             Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Conteúdo com abas -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡 Painel Administrativo" FontSize="16" FontWeight="Bold"
                               Foreground="#F5C2E7"/>
                    <Border Background="#302040" CornerRadius="4" Padding="6,2" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="ADMIN" FontSize="10" FontWeight="Bold" Foreground="#CBA6F7"/>
                    </Border>
                </StackPanel>

                <Button Content="← Voltar" HorizontalAlignment="Right"
                        Command="{Binding BackToSecretsCommand}"
                        FontSize="12" Padding="12,6"
                        Background="Transparent" Foreground="#6C7086"
                        BorderBrush="#45475A" BorderThickness="1" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderBrush" Value="#CDD6F4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Conteúdo com abas -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}"
                    Background="#1E1E2E" BorderThickness="0" Padding="0" Margin="16,8,16,0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#1E1E2E"/>
                    <Setter Property="Foreground" Value="#6C7086"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                        Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#CBA6F7"/>
                                        <Setter Property="Foreground" Value="#CDD6F4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#CDD6F4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ═══ Aba: Segredos ═══ -->
            <TabItem Header="🔑 Segredos">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Form novo segredo -->
                    <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Criar / Atualizar Segredo" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#CDD6F4" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Margin="0,0,6,0"
                                         Text="{Binding NewSecretName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Nome">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBox Grid.Column="1" Margin="0,0,6,0"
                                         Text="{Binding NewSecretValue, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Valor">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBox Grid.Column="2" Width="100" Margin="0,0,6,0"
                                         Text="{Binding NewSecretContentType, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Tipo">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <Button Grid.Column="3" Content="+ Criar"
                                        Command="{Binding CreateSecretCommand}"
                                        FontSize="12" Padding="14,6"
                                        Background="#CBA6F7" Foreground="#1E1E2E"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Lista de segredos -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Secrets}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#313244"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SecretItem}">
                                <Border Padding="12,10" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="#CDD6F4"/>
                                            <TextBlock FontSize="11" Foreground="#6C7086">
                                                <Run Text="{Binding CurrentVersion, StringFormat='v{0}'}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding ContentType}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕ Desativar"
                                                Command="{Binding DataContext.DeleteSecretCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="10,4"
                                                Background="Transparent" Foreground="#F38BA8"
                                                BorderBrush="#F38BA8" BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- ═══ Aba: AD Maps ═══ -->
            <TabItem Header="👥 AD Maps">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Form novo AD Map -->
                    <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Novo Mapeamento AD" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#CDD6F4" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Margin="0,0,6,0"
                                         Text="{Binding NewAdMapGroupId, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Grupo AD (ex: TI-Admins)">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <ComboBox Grid.Column="1" Width="120" Margin="0,0,6,0"
                                          SelectedItem="{Binding NewAdMapPermission}"
                                          FontSize="12" Padding="8,4"
                                          Background="#313244" Foreground="#CDD6F4"
                                          BorderBrush="#45475A" BorderThickness="1">
                                    <ComboBoxItem Content="Read"/>
                                    <ComboBoxItem Content="Write"/>
                                    <ComboBoxItem Content="Admin"/>
                                </ComboBox>

                                <Button Grid.Column="2" Content="+ Criar"
                                        Command="{Binding CreateAdMapCommand}"
                                        FontSize="12" Padding="14,6"
                                        Background="#CBA6F7" Foreground="#1E1E2E"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Lista de AD Maps -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding AdMaps}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#313244"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AdMapItem}">
                                <Border Padding="12,10" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding GroupId}"
                                                   FontSize="13" Foreground="#CDD6F4"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2" Margin="8,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1E3A5F"/>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Permission}" FontSize="11"
                                                       Foreground="#89B4FA" FontWeight="SemiBold"/>
                                        </Border>

                                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A3A1A"/>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" Foreground="#A6E3A1">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Ativo"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="Inativo"/>
                                                                <Setter Property="Foreground" Value="#F38BA8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <Button Grid.Column="3" Content="✕"
                                                Command="{Binding DataContext.DeleteAdMapCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="8,4"
                                                Background="Transparent" Foreground="#F38BA8"
                                                BorderBrush="#F38BA8" BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- ═══ Aba: Usuários Locais ═══ -->
            <TabItem Header="👤 Usuários">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Form novo usuário -->
                    <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Registrar Usuário Local" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#CDD6F4" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Margin="0,0,4,0"
                                         Text="{Binding NewUserUsername, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Username">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <PasswordBox x:Name="NewUserPasswordBox" Grid.Column="1" Margin="0,0,4,0"
                                             FontSize="12" Padding="8,6"
                                             Background="#313244" Foreground="#CDD6F4"
                                             BorderBrush="#45475A" BorderThickness="1">
                                    <PasswordBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </PasswordBox.Resources>
                                </PasswordBox>

                                <TextBox Grid.Column="2" Margin="0,0,4,0"
                                         Text="{Binding NewUserFirstName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Nome">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBox Grid.Column="3" Margin="0,0,4,0"
                                         Text="{Binding NewUserLastName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="#313244" Foreground="#CDD6F4"
                                         BorderBrush="#45475A" BorderThickness="1"
                                         CaretBrush="#CDD6F4" Tag="Sobrenome">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <Button x:Name="CreateUserButton" Grid.Column="4"
                                        Content="+ Criar"
                                        FontSize="12" Padding="14,6"
                                        Background="#CBA6F7" Foreground="#1E1E2E"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Lista de usuários -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Users}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#313244"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:UserItem}">
                                <Border Padding="12,10" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#302040" CornerRadius="16"
                                                Width="32" Height="32" Margin="0,0,12,0">
                                            <TextBlock Text="👤" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}" FontSize="13"
                                                       FontWeight="Medium" Foreground="#CDD6F4"/>
                                            <TextBlock FontSize="11" Foreground="#6C7086">
                                                <Run Text="{Binding FirstName}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding LastName}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#181825" Padding="16,10">
            <Grid>
                <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top"
                             Foreground="#CBA6F7" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="#A6E3A1" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
