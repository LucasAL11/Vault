<UserControl x:Class="VaultClient.Desktop.Views.SecretsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VaultClient.Desktop.Models"
             Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Search + Actions -->
            <RowDefinition Height="*"/>     <!-- List -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="20,14">
            <Grid>
                <TextBlock Text="🔐 Vault Client" FontSize="16" FontWeight="Bold"
                           Foreground="#CDD6F4" VerticalAlignment="Center"/>
                <Button Content="Sair" HorizontalAlignment="Right"
                        Command="{Binding LogoutCommand}"
                        FontSize="12" Padding="12,6"
                        Background="Transparent" Foreground="#6C7086"
                        BorderBrush="#45475A" BorderThickness="1" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderBrush" Value="#CDD6F4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Search + Refresh -->
        <Border Grid.Row="1" Padding="16,10" Background="#1E1E2E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="10,7"
                         Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" BorderThickness="1"
                         CaretBrush="#CDD6F4" Margin="0,0,8,0">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Tag" Value="Buscar segredo..."/>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1" Content="↻ Atualizar"
                        Command="{Binding LoadCommand}"
                        FontSize="12" Padding="12,7"
                        Background="#313244" Foreground="#CDD6F4"
                        BorderBrush="#45475A" BorderThickness="1" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Lista de segredos -->
        <Border Grid.Row="2" Margin="16,0,16,8">
            <Grid>
                <!-- Loading overlay -->
                <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top"
                             Foreground="#89B4FA" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                <ListBox ItemsSource="{Binding Secrets}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A3E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:SecretItem}">
                            <Border Padding="14,12" BorderBrush="#313244" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Nome + Versão -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="#CDD6F4"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                       FontSize="11" Foreground="#6C7086" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding ContentType}"
                                                       FontSize="11" Foreground="#6C7086"/>
                                            <!-- Badge de expiração próxima -->
                                            <Border Background="#45330A" CornerRadius="4"
                                                    Padding="4,1" Margin="8,0,0,0"
                                                    Visibility="{Binding Expires, Converter={StaticResource ExpiryWarningVisibility}}">
                                                <TextBlock Text="⚠ Expira em breve"
                                                           FontSize="10" Foreground="#FAB387"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Auto-Type com countdown -->
                                    <Button Grid.Column="1"
                                            Content="⌨ Auto-Type"
                                            Command="{Binding DataContext.AutoTypeCommand,
                                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            FontSize="12" Padding="12,6" Margin="0,0,8,0"
                                            Background="#313244" Foreground="#89B4FA"
                                            BorderBrush="#45475A" BorderThickness="1"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3D3F5A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Foreground" Value="#6C7086"/>
                                                        <Setter Property="BorderBrush" Value="#313244"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Estado vazio -->
                <TextBlock Text="Nenhum segredo encontrado."
                           FontSize="13" Foreground="#6C7086"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Secrets.Count, Converter={StaticResource ZeroToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Status bar / Countdown -->
        <Border Grid.Row="3" Background="#181825" Padding="16,10">
            <Grid>
                <!-- Countdown overlay -->
                <Border Background="#1E3A5F" CornerRadius="6" Padding="12,8"
                        Visibility="{Binding IsCountingDown, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontSize="13" Foreground="#89B4FA">
                            <Run Text="⌨ Foque no campo de senha. Digitando em "/>
                            <Run Text="{Binding CountdownSeconds}" FontWeight="Bold" FontSize="16"/>
                            <Run Text="s..."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Mensagem de status normal -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#A6E3A1"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsCountingDown, Converter={StaticResource InverseBoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
