<UserControl x:Class="VaultClient.Desktop.Views.SecretsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VaultClient.Desktop.Models"
             Background="{StaticResource Brush.AppBg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- List -->
            <ColumnDefinition Width="300"/>
            <!-- Detail -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.SidebarBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + status chip -->
                <Border Grid.Row="0" Padding="16,14,16,14"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5 5 L19 5 L19 9 L9 9 L9 11 L19 11 L19 19 L5 19 L5 15 L15 15 L15 13 L5 13 Z"
                                          Fill="{StaticResource Brush.Accent}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Sentil"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Fg}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource Brush.ChipBg}"
                                CornerRadius="2" Padding="6,2">
                            <TextBlock Text="UNLOCKED"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Muted}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Margin="10,10,10,0">
                    <!-- All items -->
                    <Button Style="{StaticResource SentilButtonChip}"
                            Command="{Binding OpenAdminPanelCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,0,8,0"/>
                            <TextBlock Text="Admin" FontFamily="{StaticResource Font.Body}" FontSize="12" Foreground="{StaticResource Brush.Fg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="{StaticResource Brush.Border}" Margin="0,8,0,8"/>

                    <!-- Label: vault -->
                    <TextBlock Text="COFRE ATIVO"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="10,0,0,8"/>

                    <Border Background="{StaticResource Brush.ChipBg}"
                            CornerRadius="3" Padding="10,8"
                            Visibility="{Binding VaultName, Converter={StaticResource NotEmptyToVisibility}}">
                        <TextBlock Text="{Binding VaultName}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="11" Foreground="{StaticResource Brush.Accent}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Separator Background="{StaticResource Brush.Border}" Margin="0,16,0,8"/>

                    <TextBlock Text="FILTROS"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="10,0,0,8"/>

                    <Button Style="{StaticResource SentilButtonChip}"
                            Command="{Binding LoadCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,0,8,0"/>
                            <TextBlock Text="Atualizar" FontFamily="{StaticResource Font.Body}" FontSize="12" Foreground="{StaticResource Brush.Fg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User strip + logout -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,1,0,0"
                        Padding="10,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="{StaticResource Brush.Accent}"
                                CornerRadius="14" Margin="0,0,8,0">
                            <TextBlock Text="{Binding UserInitials}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#0A120C"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + domain -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Fg}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Username}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                        </StackPanel>

                        <!-- Lock/logout -->
                        <Button Grid.Column="2"
                                Command="{Binding LogoutCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4" ToolTip="Sair"
                                Foreground="{StaticResource Brush.Muted}">
                            <TextBlock Text="🔒" FontSize="13"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             SECRET LIST
        ═══════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="{StaticResource Brush.ListBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Padding="12,10"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SentilTextBox}"
                             FontFamily="{StaticResource Font.Mono}"
                             FontSize="12"/>
                </Border>

                <!-- List -->
                <Grid Grid.Row="1">
                    <!-- Loading bar -->
                    <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top"
                                 Foreground="{StaticResource Brush.Accent}"
                                 Background="Transparent" BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                    <ListBox ItemsSource="{Binding Secrets}"
                             SelectedItem="{Binding SelectedSecret, Mode=TwoWay}"
                             Style="{StaticResource SentilListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SecretItem}">
                                <Border Padding="14,11"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon letter -->
                                        <Border Grid.Column="0" Width="28" Height="28"
                                                Background="#182219"
                                                CornerRadius="3" Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NameInitial}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource Brush.Accent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Name + meta -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Fg}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border Background="{StaticResource Brush.ChipBg}"
                                                        CornerRadius="2" Padding="4,1" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                               FontFamily="{StaticResource Font.Mono}"
                                                               FontSize="9" Foreground="{StaticResource Brush.Muted}"/>
                                                </Border>
                                                <TextBlock Text="{Binding ContentType}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                                           VerticalAlignment="Center"/>
                                                <!-- Expiry warning -->
                                                <Border Background="#2A1A04"
                                                        BorderBrush="{StaticResource Brush.Warning}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Padding="5,1" Margin="6,0,0,0"
                                                        Visibility="{Binding Expires, Converter={StaticResource ExpiryWarningVisibility}}">
                                                    <TextBlock Text="EXPIRA"
                                                               FontFamily="{StaticResource Font.Mono}"
                                                               FontSize="9" Foreground="{StaticResource Brush.Warning}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Auto-Type -->
                                        <Button Grid.Column="2"
                                                Content="▶ type"
                                                Style="{StaticResource SentilButtonGhost}"
                                                FontFamily="{StaticResource Font.Mono}"
                                                FontSize="10"
                                                Padding="8,5"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.AutoTypeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding Secrets.Count, Converter={StaticResource ZeroToVisibility}}">
                        <TextBlock Text="[ ]"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="32" Foreground="{StaticResource Brush.Border}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="nenhum segredo"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="12" Foreground="{StaticResource Brush.Muted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="// os segredos aparecerao aqui"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Border}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             DETAIL PANEL
        ═══════════════════════════════════════ -->
        <Border Grid.Column="2" Background="{StaticResource Brush.AppBg}" Padding="28,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Auto-type countdown -->
                <Border Grid.Row="0"
                        Background="#0E1F16"
                        BorderBrush="{StaticResource Brush.Accent}"
                        BorderThickness="1" CornerRadius="2"
                        Padding="14,10" Margin="0,0,0,16"
                        Visibility="{Binding IsCountingDown, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="13"
                                   Foreground="{StaticResource Brush.Accent}">
                            <Run Text="// foque no campo de senha. digitando em "/>
                            <Run Text="{Binding CountdownSeconds}" FontWeight="Bold" FontSize="16"/>
                            <Run Text="s…"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Empty state — nothing selected -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedSecret, Converter={StaticResource NotNullToVisibility}, ConverterParameter=Inverse}">
                    <TextBlock Text="[ ]"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="32" Foreground="{StaticResource Brush.Border}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="nenhum segredo selecionado"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="12" Foreground="{StaticResource Brush.Muted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Detail — secret selected -->
                <StackPanel Grid.Row="1"
                            Visibility="{Binding SelectedSecret, Converter={StaticResource NotNullToVisibility}}">

                    <!-- Label -->
                    <TextBlock Text="// SEGREDO"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="9" Foreground="{StaticResource Brush.Muted}"
                               Margin="0,0,0,10"/>

                    <!-- Name -->
                    <TextBlock Text="{Binding SelectedSecret.Name}"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Fg}"
                               Margin="0,0,0,6"/>

                    <!-- Meta chips -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Background="{StaticResource Brush.ChipBg}"
                                CornerRadius="2" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock Text="{Binding SelectedSecret.CurrentVersion, StringFormat='v{0}'}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                        </Border>
                        <Border Background="{StaticResource Brush.ChipBg}"
                                CornerRadius="2" Padding="6,2">
                            <TextBlock Text="{Binding SelectedSecret.ContentType}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                        </Border>
                    </StackPanel>

                    <!-- ── Reveal block (global admin only) ── -->
                    <StackPanel Visibility="{Binding IsGlobalAdmin, Converter={StaticResource BoolToVisibility}}">

                        <TextBlock Text="// VALOR"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}"
                                   Margin="0,0,0,8"/>

                        <!-- Revealed value box -->
                        <Border Background="{StaticResource Brush.FieldBg}"
                                BorderBrush="{StaticResource Brush.Accent}"
                                BorderThickness="1" CornerRadius="2"
                                Padding="12,10" Margin="0,0,0,10"
                                Visibility="{Binding IsRevealed, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding RevealedValue}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.Fg}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <!-- Copy button -->
                                <Button Grid.Column="1"
                                        Content="copiar"
                                        Style="{StaticResource SentilButtonGhost}"
                                        FontFamily="{StaticResource Font.Mono}"
                                        FontSize="10" Padding="8,4"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0"
                                        Command="{Binding CopyRevealedCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Auto-hide notice -->
                        <TextBlock Text="// oculta automaticamente em 15s"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding IsRevealed, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Reveal button -->
                        <Button Content="⬤ revelar senha"
                                Style="{StaticResource SentilButtonGhost}"
                                FontFamily="{StaticResource Font.Mono}"
                                FontSize="11" Padding="14,8"
                                HorizontalAlignment="Left"
                                Command="{Binding RevealCommand}"
                                CommandParameter="{Binding SelectedSecret}"
                                Visibility="{Binding IsRevealed, Converter={StaticResource InverseBoolToVisibility}}"/>

                        <!-- Loading -->
                        <ProgressBar IsIndeterminate="True" Height="2" Margin="0,8,0,0"
                                     Foreground="{StaticResource Brush.Accent}"
                                     Background="Transparent" BorderThickness="0"
                                     Visibility="{Binding IsRevealing, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <!-- Auto-type button -->
                    <Button Content="▶ auto-type"
                            Style="{StaticResource SentilButtonGhost}"
                            FontFamily="{StaticResource Font.Mono}"
                            FontSize="11" Padding="14,8"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0"
                            Command="{Binding AutoTypeCommand}"
                            CommandParameter="{Binding SelectedSecret}"/>
                </StackPanel>

                <!-- Status bar -->
                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="11" Foreground="{StaticResource Brush.Success}"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

