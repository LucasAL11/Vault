<UserControl x:Class="VaultClient.Desktop.Views.SecretsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VaultClient.Desktop.Models"
             Background="{StaticResource Brush.AppBg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- List -->
            <ColumnDefinition Width="300"/>
            <!-- Detail -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.SidebarBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + status chip -->
                <Border Grid.Row="0" Padding="16,14,16,14"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5 5 L19 5 L19 9 L9 9 L9 11 L19 11 L19 19 L5 19 L5 15 L15 15 L15 13 L5 13 Z"
                                          Fill="{StaticResource Brush.Accent}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Sentil"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Fg}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource Brush.ChipBg}"
                                CornerRadius="2" Padding="6,2">
                            <TextBlock Text="UNLOCKED"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Muted}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Margin="10,10,10,0">
                    <!-- All items -->
                    <Button Style="{StaticResource SentilButtonChip}"
                            Command="{Binding OpenAdminPanelCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,0,8,0"/>
                            <TextBlock Text="Admin" FontFamily="{StaticResource Font.Body}" FontSize="12" Foreground="{StaticResource Brush.Fg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="{StaticResource Brush.Border}" Margin="0,8,0,8"/>

                    <!-- Label: vaults -->
                    <TextBlock Text="COFRES"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="10,0,0,8"/>

                    <!-- Lista de cofres acessíveis — clique para trocar -->
                    <ItemsControl ItemsSource="{Binding AvailableVaults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:VaultItem}">
                                <Button Command="{Binding DataContext.SelectVaultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SentilButtonChip}"
                                        Padding="10,7"
                                        Margin="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Dot: aceso quando é o vault ativo -->
                                        <Ellipse Grid.Column="0"
                                                 Width="5" Height="5"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <MultiBinding Converter="{StaticResource VaultActiveDotBrush}">
                                                    <Binding Path="Id"/>
                                                    <Binding Path="DataContext.ActiveVault.Id"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Nome do cofre -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource VaultActiveFgBrush}">
                                                    <Binding Path="Id"/>
                                                    <Binding Path="DataContext.ActiveVault.Id"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Fallback quando lista ainda não carregou (ex: auth local) -->
                    <Border Background="{StaticResource Brush.ChipBg}"
                            CornerRadius="3" Padding="10,8"
                            Visibility="{Binding AvailableVaults.Count, Converter={StaticResource ZeroToVisibility}}">
                        <TextBlock Text="{Binding VaultName}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="11" Foreground="{StaticResource Brush.Accent}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Separator Background="{StaticResource Brush.Border}" Margin="0,12,0,8"/>

                    <TextBlock Text="FILTROS"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="9" Foreground="{StaticResource Brush.Muted}" Margin="10,0,0,8"/>

                    <Button Style="{StaticResource SentilButtonChip}"
                            Command="{Binding LoadCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,0,8,0"/>
                            <TextBlock Text="Atualizar" FontFamily="{StaticResource Font.Body}" FontSize="12" Foreground="{StaticResource Brush.Fg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User strip + logout -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,1,0,0"
                        Padding="10,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="28" Height="28"
                                Background="{StaticResource Brush.Accent}"
                                CornerRadius="14" Margin="0,0,8,0">
                            <TextBlock Text="{Binding UserInitials}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#0A120C"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + domain -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Fg}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Username}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10" Foreground="{StaticResource Brush.Muted}"/>
                        </StackPanel>

                        <!-- Lock/logout -->
                        <Button Grid.Column="2"
                                Command="{Binding LogoutCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4" ToolTip="Sair"
                                Foreground="{StaticResource Brush.Muted}">
                            <TextBlock Text="🔒" FontSize="13"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             SECRET LIST
        ═══════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="{StaticResource Brush.ListBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Padding="12,10"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SentilTextBox}"
                             FontFamily="{StaticResource Font.Mono}"
                             FontSize="12"/>
                </Border>

                <!-- List -->
                <Grid Grid.Row="1">
                    <!-- Loading bar -->
                    <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Top"
                                 Foreground="{StaticResource Brush.Accent}"
                                 Background="Transparent" BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                    <ListBox ItemsSource="{Binding Secrets}"
                             SelectedItem="{Binding SelectedSecret, Mode=TwoWay}"
                             Style="{StaticResource SentilListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SentilListBoxItem}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SecretItem}">
                                <Border Padding="14,11"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <!-- Active dot -->
                                            <ColumnDefinition Width="14"/>
                                            <!-- Icon letter -->
                                            <ColumnDefinition Width="Auto"/>
                                            <!-- Name + meta -->
                                            <ColumnDefinition Width="*"/>
                                            <!-- Auto-type -->
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Active dot — pulses when item is selected -->
                                        <Ellipse x:Name="ActiveDot"
                                                 Grid.Column="0"
                                                 Width="6" Height="6"
                                                 Fill="{StaticResource Brush.Accent}"
                                                 Opacity="0"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"/>

                                        <!-- Icon letter -->
                                        <Border Grid.Column="1" Width="28" Height="28"
                                                Background="#182219"
                                                CornerRadius="3" Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NameInitial}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource Brush.Accent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Name + meta -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Fg}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border Background="{StaticResource Brush.ChipBg}"
                                                        CornerRadius="2" Padding="4,1" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                               FontFamily="{StaticResource Font.Mono}"
                                                               FontSize="9" Foreground="{StaticResource Brush.Muted}"/>
                                                </Border>
                                                <TextBlock Text="{Binding ContentType}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10" Foreground="{StaticResource Brush.Muted}"
                                                           VerticalAlignment="Center"/>
                                                <!-- Expiry warning -->
                                                <Border Background="#2A1A04"
                                                        BorderBrush="{StaticResource Brush.Warning}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Padding="5,1" Margin="6,0,0,0"
                                                        Visibility="{Binding Expires, Converter={StaticResource ExpiryWarningVisibility}}">
                                                    <TextBlock Text="EXPIRA"
                                                               FontFamily="{StaticResource Font.Mono}"
                                                               FontSize="9" Foreground="{StaticResource Brush.Warning}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Auto-Type -->
                                        <Button Grid.Column="3"
                                                Content="▶ type"
                                                Style="{StaticResource SentilButtonGhost}"
                                                FontFamily="{StaticResource Font.Mono}"
                                                FontSize="10"
                                                Padding="8,5"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.AutoTypeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <!-- Dot appears and pulses when this item is the selected one -->
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                 Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="DotPulseStory">
                                                <Storyboard>
                                                    <!-- fade in -->
                                                    <DoubleAnimation Storyboard.TargetName="ActiveDot"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="0:0:0.18"/>
                                                    <!-- pulse loop — starts after fade-in -->
                                                    <DoubleAnimation Storyboard.TargetName="ActiveDot"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.35"
                                                                     Duration="0:0:0.9"
                                                                     AutoReverse="True"
                                                                     RepeatBehavior="Forever"
                                                                     BeginTime="0:0:0.18"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="DotPulseStory"/>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ActiveDot"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0"
                                                                     Duration="0:0:0.12"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding Secrets.Count, Converter={StaticResource ZeroToVisibility}}">
                        <TextBlock Text="[ ]"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="32" Foreground="{StaticResource Brush.Border}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="nenhum segredo"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="12" Foreground="{StaticResource Brush.Muted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="// os segredos aparecerao aqui"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="10" Foreground="{StaticResource Brush.Border}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             DETAIL PANEL
        ═══════════════════════════════════════ -->
        <Border Grid.Column="2" Background="{StaticResource Brush.AppBg}" Padding="28,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Auto-type countdown -->
                <Border Grid.Row="0"
                        Background="#0E1F16"
                        BorderBrush="{StaticResource Brush.Accent}"
                        BorderThickness="1" CornerRadius="2"
                        Padding="14,10" Margin="0,0,0,16"
                        Visibility="{Binding IsCountingDown, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="13"
                                   Foreground="{StaticResource Brush.Accent}">
                            <Run Text="// foque no campo de senha. digitando em "/>
                            <Run Text="{Binding CountdownSeconds}" FontWeight="Bold" FontSize="16"/>
                            <Run Text="s…"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Empty state — nothing selected -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedSecret, Converter={StaticResource NotNullToVisibility}, ConverterParameter=Inverse}">
                    <TextBlock Text="[ ]"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="32" Foreground="{StaticResource Brush.Border}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="nenhum segredo selecionado"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="12" Foreground="{StaticResource Brush.Muted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Detail — secret selected -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding SelectedSecret, Converter={StaticResource NotNullToVisibility}}">
                    <StackPanel>

                        <!-- ── Field rows card ───────────────────────────── -->
                        <Border BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1" CornerRadius="3"
                                Margin="0,0,0,12">
                            <StackPanel>

                            <!-- NOME -->
                            <Border BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="0,0,0,1">
                                <Grid Margin="16,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="84"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="NOME"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedSecret.Name}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Fg}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="2"
                                            Content="COPIAR"
                                            Style="{StaticResource SentilButtonGhost}"
                                            FontFamily="{StaticResource Font.Mono}"
                                            FontSize="10" Padding="10,5"
                                            Command="{Binding CopyNameCommand}"/>
                                </Grid>
                            </Border>

                            <!-- SENHA (apenas admin global) -->
                            <Border Visibility="{Binding IsGlobalAdmin, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="16,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="84"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="SENHA"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}"
                                               VerticalAlignment="Center"/>

                                    <!-- Valor mascarado -->
                                    <TextBlock Grid.Column="1"
                                               Text="●●●●●●●●●●●●●●"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="13"
                                               Foreground="{StaticResource Brush.Muted}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsRevealed, Converter={StaticResource InverseBoolToVisibility}}"/>

                                    <!-- Valor revelado -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RevealedValue}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="13"
                                               Foreground="{StaticResource Brush.Accent}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsRevealed, Converter={StaticResource BoolToVisibility}}"/>

                                    <!-- Ícone olho: revelar / ocultar -->
                                    <Button Grid.Column="2"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="8,0" Margin="4,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Revelar / Ocultar">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Command" Value="{Binding RevealCommand}"/>
                                                <Setter Property="CommandParameter" Value="{Binding SelectedSecret}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                        <Setter Property="Command" Value="{Binding HideRevealedCommand}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z"
                                                      Stroke="#737373" StrokeThickness="1.6" Fill="Transparent"
                                                      StrokeLineJoin="Round"/>
                                                <Ellipse Canvas.Left="9" Canvas.Top="9"
                                                         Width="6" Height="6"
                                                         Stroke="#737373" StrokeThickness="1.6"
                                                         Fill="Transparent"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Button>

                                    <!-- COPIAR senha -->
                                    <Button Grid.Column="3"
                                            Content="COPIAR"
                                            Style="{StaticResource SentilButtonGhost}"
                                            FontFamily="{StaticResource Font.Mono}"
                                            FontSize="10" Padding="10,5"
                                            Command="{Binding CopyRevealedCommand}"
                                            IsEnabled="{Binding IsRevealed}"/>
                                </Grid>

                            </Border>

                            </StackPanel>
                        </Border>

                        <!-- ── Loading bar (reveal em andamento) ─────────── -->
                        <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,12"
                                     Foreground="{StaticResource Brush.Accent}"
                                     Background="Transparent" BorderThickness="0"
                                     Visibility="{Binding IsRevealing, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- ── Stats grid ─────────────────────────────────── -->
                        <Border BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1" CornerRadius="3"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- VERSÃO -->
                                <StackPanel Grid.Column="0" Margin="16,12">
                                    <TextBlock Text="VERSÃO"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SelectedSecret.CurrentVersion, StringFormat='v{0}'}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource Brush.Fg}"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource Brush.Border}"/>

                                <!-- TIPO -->
                                <StackPanel Grid.Column="2" Margin="16,12">
                                    <TextBlock Text="TIPO"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SelectedSecret.ContentType}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Fg}"/>
                                </StackPanel>

                                <Border Grid.Column="3" Background="{StaticResource Brush.Border}"/>

                                <!-- EXPIRA -->
                                <StackPanel Grid.Column="4" Margin="16,12">
                                    <TextBlock Text="EXPIRA"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock FontFamily="{StaticResource Font.Mono}"
                                               FontSize="13" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Muted}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSecret.Expires, Converter={StaticResource ExpiryWarningVisibility}}"
                                                                 Value="Visible">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Warning}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedSecret.Expires, StringFormat='{}{0:dd/MM/yyyy}'}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="11" Foreground="{StaticResource Brush.Warning}"
                                               Visibility="{Binding SelectedSecret.Expires, Converter={StaticResource ExpiryWarningVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Auto-hide notice ───────────────────────────── -->
                        <TextBlock Text="// oculta automaticamente em 15s"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="9" Foreground="{StaticResource Brush.Muted}"
                                   Margin="0,0,0,16"
                                   Visibility="{Binding IsRevealed, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- ── Auto-type ──────────────────────────────────── -->
                        <Button Content="▶  auto-type"
                                Style="{StaticResource SentilButtonGhost}"
                                FontFamily="{StaticResource Font.Mono}"
                                FontSize="11" Padding="14,9"
                                HorizontalAlignment="Left"
                                Command="{Binding AutoTypeCommand}"
                                CommandParameter="{Binding SelectedSecret}"/>

                        <!-- ── Recent Activity (apenas admin) ────────────── -->
                        <StackPanel Margin="0,24,0,0"
                                    Visibility="{Binding IsGlobalAdmin, Converter={StaticResource BoolToVisibility}}">

                            <!-- Header -->
                            <TextBlock Text="ATIVIDADE RECENTE"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Muted}"
                                       Margin="0,0,0,10"/>

                            <!-- Loading spinner -->
                            <TextBlock Text="carregando..."
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                       Visibility="{Binding IsLoadingAudit, Converter={StaticResource BoolToVisibility}}"/>

                            <!-- Empty state -->
                            <TextBlock Text="sem registros"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11" Foreground="{StaticResource Brush.Muted}"
                                       Visibility="{Binding HasAuditEntries, Converter={StaticResource InverseBoolToVisibility}}"/>

                            <!-- Entries -->
                            <ItemsControl ItemsSource="{Binding AuditEntries}"
                                          Visibility="{Binding HasAuditEntries, Converter={StaticResource BoolToVisibility}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding OccurredAtUtc, Converter={StaticResource RelativeTime}}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource Brush.Muted}"
                                                       VerticalAlignment="Top"/>

                                            <!-- Actor + Action -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        FlowDirection="LeftToRight">
                                                <TextBlock Text="{Binding Actor, Converter={StaticResource ActorName}}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{StaticResource Brush.Fg}"
                                                           Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Action, Converter={StaticResource AuditActionLabel}}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource Brush.Muted}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Status bar -->
                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="11" Foreground="{StaticResource Brush.Success}"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

