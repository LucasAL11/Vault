<Window x:Class="VaultClient.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VaultClient.Desktop.Views"
        Title="Vault Client" Height="650" Width="980"
        MinHeight="520" MinWidth="780"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <!-- Setup (first use or reconfiguration) -->
        <Grid x:Name="SetupPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
              Visibility="Collapsed">
            <views:SetupView x:Name="SetupViewControl"/>
        </Grid>

        <!-- Login -->
        <Grid x:Name="LoginPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
              Visibility="Collapsed">
            <views:LoginView x:Name="LoginViewControl"/>
        </Grid>

        <!-- Secrets (full window) -->
        <views:SecretsView x:Name="SecretsViewControl" Visibility="Collapsed"/>

        <!-- Admin (full window, AD Admins only) -->
        <views:AdminView x:Name="AdminViewControl" Visibility="Collapsed"/>
    </Grid>
</Window>
