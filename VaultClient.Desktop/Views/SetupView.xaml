<UserControl x:Class="VaultClient.Desktop.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="440">

    <Border Background="#181825" CornerRadius="12" Padding="44,36"
            BorderBrush="#313244" BorderThickness="1">
        <StackPanel>

            <!-- Title -->
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="#252537" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="&#x2699;" FontSize="24"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Configuracao do Vault"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Conecte ao servidor do cofre de senhas"
                       FontSize="12" Foreground="#6C7086"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <!-- Server URL -->
            <TextBlock Text="URL do Servidor" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="BaseUrlBox"
                     Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="12,10"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,4">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>
            <TextBlock Text="Ex: https://vault.empresa.com" FontSize="10"
                       Foreground="#585B70" Margin="0,0,0,16"/>

            <!-- Vault ID -->
            <TextBlock Text="Vault ID (GUID)" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="VaultIdBox"
                     Text="{Binding VaultId, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="12,10"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,4">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>
            <TextBlock Text="Identificador unico do cofre (pode ser obtido no painel admin)"
                       FontSize="10" Foreground="#585B70" Margin="0,0,0,16"/>

            <!-- Client ID -->
            <TextBlock Text="Client ID" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="ClientIdBox"
                     Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="12,10"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,16">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>

            <!-- AD Domain (optional) -->
            <TextBlock Text="Dominio AD (opcional)" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="DomainBox"
                     Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="12,10"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,4">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>
            <TextBlock Text="Deixe vazio para login apenas local"
                       FontSize="10" Foreground="#585B70" Margin="0,0,0,16"/>

            <!-- Client Secret -->
            <TextBlock Text="Client Secret" Foreground="#BAC2DE" FontSize="12"
                       FontWeight="SemiBold" Margin="0,0,0,6"/>
            <PasswordBox x:Name="ClientSecretBox"
                         FontSize="13" Padding="12,10"
                         Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" BorderThickness="1"
                         Margin="0,0,0,4">
                <PasswordBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </PasswordBox.Resources>
            </PasswordBox>
            <TextBlock Text="Protegido com DPAPI (criptografia do perfil Windows)"
                       FontSize="10" Foreground="#585B70" Margin="0,0,0,20"/>

            <!-- Error message -->
            <Border Background="#2B0D0D" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NotEmptyToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#F38BA8" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Success message -->
            <Border Background="#0D2B0D" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding ConnectionVerified, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2713; " Foreground="#A6E3A1" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#A6E3A1" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Test Connection button -->
            <Button x:Name="TestButton"
                    Content="Testar Conexao"
                    FontSize="13" Padding="0,10" Margin="0,0,0,8"
                    Background="#313244" Foreground="#89B4FA"
                    BorderBrush="#45475A" BorderThickness="1"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3F5A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6C7086"/>
                                <Setter Property="BorderBrush" Value="#313244"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Save button -->
            <Button x:Name="SaveButton"
                    Content="Salvar Configuracao"
                    FontSize="14" FontWeight="SemiBold"
                    Padding="0,12"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#89B4FA"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4D0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,12,0,0"
                         Foreground="#89B4FA" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

        </StackPanel>
    </Border>
</UserControl>
