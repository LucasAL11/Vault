<UserControl x:Class="VaultClient.Desktop.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420">

    <Border Background="#1E1E2E" CornerRadius="12" Padding="40,36">
        <StackPanel>

            <!-- Título -->
            <TextBlock Text="&#x1F511; Configuracao do Vault"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Conecte ao servidor do cofre de senhas"
                       FontSize="12" Foreground="#6C7086"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <!-- URL do Servidor -->
            <TextBlock Text="URL do Servidor" Foreground="#BAC2DE" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="BaseUrlBox"
                     Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="10,8"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,4">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>
            <TextBlock Text="Ex: https://vault.empresa.com" FontSize="10"
                       Foreground="#6C7086" Margin="0,0,0,14"/>

            <!-- Vault ID -->
            <TextBlock Text="Vault ID (GUID)" Foreground="#BAC2DE" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="VaultIdBox"
                     Text="{Binding VaultId, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="10,8"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,4">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>
            <TextBlock Text="Ex: 11111111-1111-1111-1111-111111111111" FontSize="10"
                       Foreground="#6C7086" Margin="0,0,0,14"/>

            <!-- Client ID -->
            <TextBlock Text="Client ID" Foreground="#BAC2DE" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="ClientIdBox"
                     Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="10,8"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     CaretBrush="#CDD6F4" Margin="0,0,0,16">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </TextBox.Resources>
            </TextBox>

            <!-- Client Secret (sem toggle de visualizacao) -->
            <TextBlock Text="Client Secret" Foreground="#BAC2DE" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ClientSecretBox"
                         FontSize="13" Padding="10,8"
                         Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" BorderThickness="1"
                         Margin="0,0,0,4">
                <PasswordBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </PasswordBox.Resources>
            </PasswordBox>
            <TextBlock Text="Armazenado com DPAPI (perfil do usuario Windows)"
                       FontSize="10" Foreground="#6C7086" Margin="0,0,0,20"/>

            <!-- Mensagem de erro -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#F38BA8" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NotEmptyToVisibility}}"
                       Margin="0,0,0,8"/>

            <!-- Mensagem de sucesso da conexao -->
            <Border Background="#0D2B0D" CornerRadius="6" Padding="10,7" Margin="0,0,0,12"
                    Visibility="{Binding ConnectionVerified, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2713; " Foreground="#A6E3A1" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#A6E3A1" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Botao Testar Conexao -->
            <Button x:Name="TestButton"
                    Content="Testar Conexao"
                    FontSize="13" Padding="0,9" Margin="0,0,0,8"
                    Background="#313244" Foreground="#89B4FA"
                    BorderBrush="#45475A" BorderThickness="1"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3F5A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6C7086"/>
                                <Setter Property="BorderBrush" Value="#313244"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Botao Salvar (habilitado somente apos conexao verificada) -->
            <Button x:Name="SaveButton"
                    Content="Salvar Configuracao"
                    FontSize="14" FontWeight="SemiBold"
                    Padding="0,10"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#89B4FA"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4D0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,12,0,0"
                         Foreground="#89B4FA" Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

        </StackPanel>
    </Border>
</UserControl>
