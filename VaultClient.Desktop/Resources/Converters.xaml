<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:res="clr-namespace:VaultClient.Desktop.Resources">

    <res:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    <res:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    <res:NotEmptyToVisibilityConverter x:Key="NotEmptyToVisibility"/>
    <res:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
    <res:ExpiryWarningVisibilityConverter x:Key="ExpiryWarningVisibility"/>
    <!-- null → Collapsed, non-null → Visible -->
    <res:NullToVisibilityConverter x:Key="NotNullToVisibility"/>
    <!-- null → Visible, non-null → Collapsed -->
    <res:NullToVisibilityConverter x:Key="NullToVisibility" />
    <res:RelativeTimeConverter      x:Key="RelativeTime"/>
    <res:AuditActionLabelConverter  x:Key="AuditActionLabel"/>
    <res:ActorNameConverter         x:Key="ActorName"/>
    <res:StatusTypeToBrushConverter x:Key="StatusTypeToBrush"/>
    <res:StatusTypeToBgBrushConverter x:Key="StatusTypeToBgBrush"/>
    <res:SelectedItemBrushConverter x:Key="SelectedItemBrush"/>
    <!-- Vault ativo — dot verde aceso, texto accent -->
    <res:GuidEqualToBrushConverter x:Key="VaultActiveDotBrush"
                                   TrueBrush="#5BAD80"
                                   FalseBrush="Transparent"/>
    <res:GuidEqualToBrushConverter x:Key="VaultActiveFgBrush"
                                   TrueBrush="#5BAD80"
                                   FalseBrush="#737373"/>

</ResourceDictionary>
