{
  "Logging":{
    "LogLevel":{
      "Default":"Information",
      "Microsoft.AspNetCore":"Warning"
    }
  },
  "Jwt":{
    "Issuer":"WebApplication1",
    "Audience":"WebApplication1",
    "Secret":"dev-shared-secret-please-rotate",
    "ExpirationMinutes":60
  },
  "Authentication":{
    "Kerberos":{
      "Enabled":true
    },
    "Ldap":{
      "Enabled":true,
      "Domain":"",
      "Container":""
    },
    "Oidc":{
      "Enabled":false,
      "Authority":"",
      "Issuer":"",
      "Audience":"",
      "RequireHttpsMetadata":true,
      "RoleClaimType":"groups",
      "NameClaimType":"name"
    }
  },
  "KillSwitch":{
    "Enabled":false,
    "AllowedGroup":"Administradores de Chaves",
    "RetryAfterSeconds":120,
    "Message":"Service temporarily unavailable.",
    "DenyUsers":[]
  },
  "AllowedHosts":"*",
  "KeyProvider":{
    "Mode":"Dev",
    "OperatorsGroup":"Administradores de Chaves",
    "Dev":{
      "KeyId":"dev-local-key-v1",
      "Base64Key":"MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY="
    },
    "Prod":{
      "CurrentKeyId":"prod-key-v1",
      "Keys":[
        {
          "KeyId":"prod-key-v1",
          "Base64Key":""
        }
      ]
    },
    "ProdKms":{
      "Enabled":false,
      "BaseUrl":"https://kms.internal.local",
      "KeysEndpointPath":"/v1/keyring",
      "RotateEndpointPath":"/v1/keyring/rotate",
      "ApiKey":"",
      "ApiKeyHeaderName":"X-API-Key",
      "TimeoutSeconds":5,
      "CacheTtlSeconds":30
    }
  },
  "NonceStore":{
    "Provider":"InMemory",
    "Enabled":true,
    "TtlSeconds":300,
    "MaxEntries":50000
  },
  "AuthChallenge":{
    "ClockSkewSeconds":60,
    "ClientSecrets":{
      "local-dev-client":"change-me-dev-shared-secret"
    }
  },
  "SecretVersionRetention":{
    "Rules":[
      {"Name":"prod-credential","Environment":"Production","SecretType":"Credential","MaxVersionsToRetain":20,"RequireExpiration":true,"DefaultExpirationDays":30,"MinExpirationMinutes":60,"MaxExpirationDays":90},
      {"Name":"prod-token","Environment":"Production","SecretType":"Token","MaxVersionsToRetain":10,"RequireExpiration":true,"DefaultExpirationDays":7,"MinExpirationMinutes":15,"MaxExpirationDays":14},
      {"Name":"prod-certificate","Environment":"Production","SecretType":"Certificate","MaxVersionsToRetain":8,"RequireExpiration":true,"DefaultExpirationDays":365,"MinExpirationMinutes":1440,"MaxExpirationDays":825},
      {"Name":"prod-generic","Environment":"Production","SecretType":"Generic","MaxVersionsToRetain":30,"RequireExpiration":false,"DefaultExpirationDays":90,"MinExpirationMinutes":15,"MaxExpirationDays":365},
      {"Name":"staging-credential","Environment":"Staging","SecretType":"Credential","MaxVersionsToRetain":10,"RequireExpiration":true,"DefaultExpirationDays":14,"MinExpirationMinutes":30,"MaxExpirationDays":30},
      {"Name":"staging-token","Environment":"Staging","SecretType":"Token","MaxVersionsToRetain":8,"RequireExpiration":true,"DefaultExpirationDays":3,"MinExpirationMinutes":10,"MaxExpirationDays":14},
      {"Name":"staging-certificate","Environment":"Staging","SecretType":"Certificate","MaxVersionsToRetain":6,"RequireExpiration":true,"DefaultExpirationDays":90,"MinExpirationMinutes":1440,"MaxExpirationDays":365},
      {"Name":"staging-generic","Environment":"Staging","SecretType":"Generic","MaxVersionsToRetain":15,"RequireExpiration":false,"DefaultExpirationDays":30,"MinExpirationMinutes":10,"MaxExpirationDays":180},
      {"Name":"development-credential","Environment":"Development","SecretType":"Credential","MaxVersionsToRetain":5,"RequireExpiration":true,"DefaultExpirationDays":3,"MinExpirationMinutes":10,"MaxExpirationDays":14},
      {"Name":"development-token","Environment":"Development","SecretType":"Token","MaxVersionsToRetain":5,"RequireExpiration":true,"DefaultExpirationDays":1,"MinExpirationMinutes":5,"MaxExpirationDays":7},
      {"Name":"development-certificate","Environment":"Development","SecretType":"Certificate","MaxVersionsToRetain":5,"RequireExpiration":true,"DefaultExpirationDays":30,"MinExpirationMinutes":60,"MaxExpirationDays":90},
      {"Name":"development-generic","Environment":"Development","SecretType":"Generic","MaxVersionsToRetain":10,"RequireExpiration":false,"DefaultExpirationDays":7,"MinExpirationMinutes":5,"MaxExpirationDays":30},
      {"Name":"fallback","Environment":"*","SecretType":"*","MaxVersionsToRetain":20,"RequireExpiration":false,"DefaultExpirationDays":30,"MinExpirationMinutes":15,"MaxExpirationDays":180}
    ]
  },
  "Cors":{
    "AllowedOrigins":[],
    "AllowedMethods":[
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders":[
      "Authorization",
      "Content-Type",
      "X-Requested-With",
      "X-Correlation-Id",
      "X-Trace-Id"
    ],
    "ExposedHeaders":[
      "X-Correlation-Id",
      "X-Trace-Id",
      "X-API-Version",
      "Retry-After"
    ],
    "AllowCredentials":false,
    "PreflightMaxAgeSeconds":600
  },
  "SecurityHeaders":{
    "XFrameOptions":"DENY",
    "ContentSecurityPolicy":"default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'",
    "ReferrerPolicy":"no-referrer",
    "PermissionsPolicy":"accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
    "CrossOriginOpenerPolicy":"same-origin",
    "CrossOriginResourcePolicy":"same-origin",
    "XPermittedCrossDomainPolicies":"none"
  },
  "RateLimiting":{
    "RetryAfterSeconds":60,
    "SecretRead":{"PermitLimit":20,"WindowSeconds":60,"QueueLimit":0},
    "SecretWrite":{"PermitLimit":10,"WindowSeconds":60,"QueueLimit":0},
    "SecretAuditRead":{"PermitLimit":10,"WindowSeconds":60,"QueueLimit":0},
    "AuthChallenge":{"PermitLimit":30,"WindowSeconds":60,"QueueLimit":0},
    "AuthChallengeVerify":{"PermitLimit":60,"WindowSeconds":60,"QueueLimit":0},
    "AuthChallengeRespond":{"PermitLimit":20,"WindowSeconds":60,"QueueLimit":0},
    "OpsSensitive":{"PermitLimit":20,"WindowSeconds":60,"QueueLimit":0}
  }
}
