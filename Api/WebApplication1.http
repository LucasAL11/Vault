@baseUrl = http://localhost:5065
@username = lucas.luna
@domain = plt
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..qHPjjgZM2Z4ZSm4ii6DrYiossYmGUYnX-9F7OPIME5s
@secret = 42
@hashPublic =
@proof =
@zkClientId = local-dev-client
@zkNonce =
@killswitchEnabled = true
@vaultId = 11111111-1111-1111-1111-111111111111

###
# 1) Hora do servidor (publico)
GET {{baseUrl}}/debug/time
Accept: application/json

###
# 2) Gerar token JWT (publico)
# Ajuste username/domain para valores validos no seu AD/contexto.
POST {{baseUrl}}/users
Content-Type: application/json
Accept: application/json

{
  "username": "{{username}}",
  "domain": "{{domain}}"
}

> {%
  if (response.status === 200) {
    client.global.set("token", response.body);
  }
%}

###
# 3) Gerar hashPublic automatico a partir do secret
POST {{baseUrl}}/Cryptography/hash
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "secret": "{{secret}}"
}

> {%
  if (response.status === 200 && response.body && response.body.HashBase64) {
    client.global.set("hashPublic", response.body.HashBase64);
  }
%}

###
# 4) Debug de autenticacao (requer auth)
GET {{baseUrl}}/debug/auth
Authorization: Bearer {{token}}
Accept: application/json

###
# 4.1) Debug do KeyProvider (requer auth)
GET {{baseUrl}}/debug/key-provider
Authorization: Bearer {{token}}
Accept: application/json

###
# 4.2) Operacao do KeyProvider (requer auth + grupo de operadores)
GET {{baseUrl}}/ops/key-provider
Authorization: Bearer {{token}}
Accept: application/json

###
# 4.3) Rotacionar chave corrente em runtime (requer auth + grupo de operadores)
POST {{baseUrl}}/ops/key-provider/rotate
Content-Type: application/json
Authorization: Bearer {{token}}
Accept: application/json

{
  "keyId": "prod-key-v2"
}

###
# 4.4) Re-encrypt de versoes antigas para chave corrente (requer auth + grupo de operadores)
POST {{baseUrl}}/ops/key-provider/re-encrypt
Content-Type: application/json
Authorization: Bearer {{token}}
Accept: application/json

{
  "vaultId": "{{vaultId}}",
  "secretName": "DB_PASSWORD",
  "includeRevoked": false,
  "includeExpired": false
}

###
# 5) Listar grupos do usuario autenticado (requer auth)
GET {{baseUrl}}/users/groups
Authorization: Bearer {{token}}
Accept: application/json

###
# 6) Exemplo de policy por grupo AD (requer grupo vendasss)
GET {{baseUrl}}/users/ad-group-example
Authorization: Bearer {{token}}
Accept: application/json

###
# 7) Endpoint com policy de grupo NomeDoGrupo (requer auth + policy)
GET {{baseUrl}}/users/1
Authorization: Bearer {{token}}
Accept: application/json

###
# 8) Registrar computador
POST {{baseUrl}}/computers
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "name": "PC-DEV-01",
  "cpuId": "BFEBFBFF000906ED",
  "biosSerial": "BIOS-SERIAL-12345",
  "diskSerial": "DISK-SERIAL-67890",
  "operatingSystem": "Windows 11 Pro",
  "machineGuid": "31f232f2-84f4-4c8d-9002-f33e5364ad14"
}

###
# 9) Gerar prova ZK (hashPublic vem do passo 3)
POST {{baseUrl}}/auth/challenge
Content-Type: application/json
Accept: application/json

{
  "clientId": "{{zkClientId}}"
}

> {%
  if (response.status === 200 && response.body && response.body.nonce) {
    client.global.set("zkNonce", response.body.nonce);
  }
%}

###
# 10) Gerar prova ZK (hashPublic vem do passo 3)
POST {{baseUrl}}/Cryptography/zk
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "secret": "{{secret}}",
  "hashPublic": "{{hashPublic}}",
  "clientId": "{{zkClientId}}",
  "nonce": "{{zkNonce}}"
}

> {%
  if (response.status === 200) {
    client.global.set("proof", response.body);
  }
%}

###
# 11) Obter nonce para verify
POST {{baseUrl}}/auth/challenge
Content-Type: application/json
Accept: application/json

{
  "clientId": "{{zkClientId}}"
}

> {%
  if (response.status === 200 && response.body && response.body.nonce) {
    client.global.set("zkNonce", response.body.nonce);
  }
%}

###
# 12) Verificar prova ZK
POST {{baseUrl}}/Cryptography/verify
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "proof": "{{proof}}",
  "hashPublic": "{{hashPublic}}",
  "clientId": "{{zkClientId}}",
  "nonce": "{{zkNonce}}"
}

###
# 13) Exemplo sem token (esperado 401 em endpoints protegidos)
GET {{baseUrl}}/users/groups
Accept: application/json

###
# 12) Ver status do Kill Switch (requer auth + grupo AllowedGroup)
GET {{baseUrl}}/ops/killswitch
Authorization: Bearer {{token}}
Accept: application/json

###
# 13) Ativar/desativar Kill Switch (requer auth + grupo AllowedGroup)
POST {{baseUrl}}/ops/killswitch
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "enabled": {{killswitchEnabled}},
  "allowedGroup": "Admins",
  "retryAfterSeconds": 120,
  "message": "Service temporarily unavailable."
}

###
# 14) Com kill switch ativo: endpoints comuns devem retornar 503
GET {{baseUrl}}/debug/time
Accept: application/json

###
# 15) Debug de autorizacao do kill switch (requer auth)
GET {{baseUrl}}/ops/killswitch/debug
Authorization: Bearer {{token}}
Accept: application/json

###
# 16) Listar denylist temporaria (requer auth + grupo AllowedGroup)
GET {{baseUrl}}/ops/killswitch/denylist
Authorization: Bearer {{token}}
Accept: application/json

###
# 17) Adicionar usuario na denylist por 30 minutos
POST {{baseUrl}}/ops/killswitch/denylist
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "username": "lucas.luna",
  "durationMinutes": 30,
  "reason": "Investigacao de incidente"
}

###
# 18) Remover usuario da denylist
DELETE {{baseUrl}}/ops/killswitch/denylist/lucas.luna
Authorization: Bearer {{token}}
Accept: application/json

###
# 19) Teste de mascaramento de segredos em logs (headers + query)
GET {{baseUrl}}/debug/auth?token=token-super-secreto&secret=minha-chave&api-key=123456&q=ok
Authorization: Bearer {{token}}
Cookie: sessionid=abc123
X-Api-Key: 999999
Accept: application/json

###
# 20) Gravar segredo criptografado em repouso (requer auth)
PUT {{baseUrl}}/vaults/{{vaultId}}/secrets/DB_PASSWORD
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "value": "Senha@SuperSecreta!",
  "contentType": "text/plain",
  "expiresUtc": null
}

###
# 21) Ler metadados do segredo (sem plaintext, requer auth + policy do Vault)
GET {{baseUrl}}/vaults/{{vaultId}}/secrets/DB_PASSWORD
Authorization: Bearer {{token}}
Accept: application/json

###
# 22) Listar metadados de versoes do segredo (sem plaintext)
GET {{baseUrl}}/vaults/{{vaultId}}/secrets/DB_PASSWORD/versions
Authorization: Bearer {{token}}
Accept: application/json

###
# 23) Listar versoes com filtros (includeRevoked/fromVersion/toVersion)
GET {{baseUrl}}/vaults/{{vaultId}}/secrets/DB_PASSWORD/versions?includeRevoked=true&fromVersion=1&toVersion=10
Authorization: Bearer {{token}}
Accept: application/json

###
# 24) Consultar trilha de auditoria do segredo (read/write/rotate/re-encrypt)
GET {{baseUrl}}/vaults/{{vaultId}}/secrets/DB_PASSWORD/audit?take=100
Authorization: Bearer {{token}}
Accept: application/json

###
# 25) Anti-abuso/rate-limit: repita rapidamente requests 21/22/24 e valide 429
# Esperado em excesso: HTTP 429 + Retry-After: 60
